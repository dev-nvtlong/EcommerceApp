@model EcommerceApp.Application.DTOs.Order.OrderDto
@using EcommerceApp.Enums

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title fw-bold" id="orderModalLabel">Chi tiết đơn hàng #@Model.Id</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body p-4">
    <div class="row g-4">
        <!-- Thông tin người nhận lên trên -->
        <div class="col-lg-12">
            <div class="card border shadow-none rounded-4 p-4 mb-0 bg-light-subtle">
                <h6 class="fw-bold mb-3 text-primary"><i class="fa-solid fa-user me-2"></i>Thông tin nhận hàng</h6>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Người nhận</label>
                        <div class="fw-semibold">@Model.ShipName</div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Số điện thoại</label>
                        <div>@Model.ShipPhone</div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Email</label>
                        <div class="text-truncate">@Model.CustomerEmail</div>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Địa chỉ giao hàng</label>
                        <div class="text-dark small">@Model.ShipAddress</div>
                    </div>
                    <div class="col-md-4 mb-0">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Thanh toán</label>
                        <span class="badge bg-white @(Model.PaymentMethod == PaymentMethod.Banking ? "text-info border-info" : "text-dark border-dark") border">
                            @(Model.PaymentMethod == PaymentMethod.Banking ? "Chuyển khoản" : "Tiền mặt")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm -->
        <div class="col-lg-12">
            <div class="card border shadow-none rounded-4 overflow-hidden mb-0">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <h6 class="mb-0 fw-bold"><i class="fa-solid fa-box me-2"></i>Danh sách sản phẩm</h6>
                </div>
                
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase sticky-top" style="z-index: 10;">
                            <tr>
                                <th class="ps-4 border-0">Sản phẩm</th>
                                <th class="text-center border-0">SL</th>
                                <th class="text-end pe-4 border-0">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Details)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            @if (item.Product?.ImageUrls != null && item.Product.ImageUrls.Any())
                                            {
                                                <img src="@item.Product.ImageUrls[0]" class="rounded-3 me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                            }
                                            <div style="max-width: 250px;">
                                                <div class="fw-bold text-dark text-truncate" title="@item.Product.Name">@item.Product.Name</div>
                                                <div class="text-muted small">@item.Price.ToString("N0") ₫</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold">@item.SubTotal.ToString("N0") ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Footer của card được làm sticky để giữ tổng tiền -->
                <div class="card-footer bg-light border-0 py-3 px-4 border-top sticky-bottom">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-uppercase small text-muted">Tổng thanh toán:</span>
                        <span class="h4 fw-bold text-primary mb-0">@Model.TotalAmount.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-footer border-0 pt-0">
    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
</div>

<style>
    .sticky-top {
        position: sticky;
        top: 0;
        background-color: #f8f9fa !important;
    }
    .sticky-bottom {
        position: sticky;
        bottom: 0;
        z-index: 10;
        box-shadow: 0 -4px 10px rgba(0,0,0,0.05);
    }
</style>
