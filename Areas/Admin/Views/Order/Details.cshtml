@model EcommerceApp.Application.DTOs.Order.OrderDto
@using EcommerceApp.Enums
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index">Quản lý đơn hàng</a></li>
            <li class="breadcrumb-item active">Chi tiết đơn hàng #@Model.Id</li>
        </ol>
    </nav>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 btn-sm">
        <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-0 py-3 px-4">
                <h5 class="mb-0 fw-bold">Danh sách sản phẩm</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Details)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        @if (item.Product?.ImageUrls != null && item.Product.ImageUrls.Any())
                                        {
                                            <img src="@item.Product.ImageUrls[0]" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                        }
                                        <div>
                                            <div class="fw-bold text-dark">@item.Product.Name</div>
                                            <div class="text-muted small">@item.Price.ToString("N0") ₫</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">x @item.Quantity</td>
                                <td class="text-end pe-4 fw-bold">@item.SubTotal.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-white border-0 py-3 px-4 border-top">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Tổng tiền:</span>
                    <span class="h4 fw-bold text-primary mb-0">@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="fw-bold mb-4">Thông tin nhận hàng</h5>
            <div class="mb-3">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Họ tên người nhận</label>
                <div class="fw-semibold">@Model.ShipName</div>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Email liên hệ</label>
                <div>@Model.CustomerEmail</div>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Số điện thoại</label>
                <div>@Model.ShipPhone</div>
            </div>
            <div class="mb-3">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Địa chỉ giao hàng</label>
                <div class="text-dark">@Model.ShipAddress</div>
            </div>
            <div class="mb-0">
                <label class="text-muted small fw-bold text-uppercase d-block mb-1">Phương thức thanh toán</label>
                <span class="badge bg-light @(Model.PaymentMethod == PaymentMethod.Banking ? "text-info" : "text-dark") border">
                    @(Model.PaymentMethod == PaymentMethod.Banking ? "Chuyển khoản" : "Tiền mặt")
                </span>
            </div>
        </div>
    </div>
</div>
