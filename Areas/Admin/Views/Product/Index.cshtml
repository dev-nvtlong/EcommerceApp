@model IEnumerable<EcommerceApp.Application.DTOs.Product.ProductDto>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var categories = ViewBag.Categories as List<EcommerceApp.Application.DTOs.Category.CategoryDto>;
}

<style>
    .product-page {
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .product-page__title {
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .product-page__card {
        transition: var(--transition);
        overflow: hidden;
    }

    .product-page__card:hover {
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
    }

    .product-table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.8px;
        color: var(--text-muted);
        border-top: none;
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .product-table tbody tr {
        transition: var(--transition);
    }

    .product-table tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.02);
    }

    .product-table__img-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        background-color: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-table__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .product-table__name {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-main);
    }

    .product-table__price {
        font-weight: 600;
        color: var(--primary-color);
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 10px;
        transition: var(--transition);
        background: none;
    }

    .btn-action--edit {
        color: var(--primary-color);
        background-color: rgba(99, 102, 241, 0.1);
    }

    .btn-action--edit:hover {
        background-color: var(--primary-color);
        color: white;
    }

    .btn-action--delete {
        color: #ef4444;
        background-color: rgba(239, 68, 68, 0.1);
    }

    .btn-action--delete:hover {
        background-color: #ef4444;
        color: white;
    }

    /* Modal Styling */
    .modal-content {
        border: none;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .modal-header {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .form-label {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-control, .form-select {
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
        transition: var(--transition);
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
</style>

<div class="product-page">
    <div class="product-page__header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="product-page__title">Sản phẩm</h2>
            <p class="text-muted">Quản lý kho hàng, thông tin sản phẩm và giá bán.</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-2" onclick="openModal()">
            <i class="fa-solid fa-plus"></i>
            Thêm sản phẩm
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="product-page__card card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 product-table">
                    <thead>
                        <tr>
                            <th class="px-4 py-3" style="width: 80px;">Hình ảnh</th>
                            <th class="py-3">Tên sản phẩm</th>
                            <th class="py-3">Danh mục</th>
                            <th class="py-3">Giá bán</th>
                            <th class="py-3 text-end px-4" style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="product-table__img-wrapper">
                                            @if (item.ImageUrls != null && item.ImageUrls.Any())
                                            {
                                                <img src="@item.ImageUrls.First()" alt="Product" class="product-table__img">
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-image text-muted opacity-50"></i>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="product-table__name">@item.Name</div>
                                        <div class="text-muted small">#@item.ProductId</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark fw-medium rounded-pill px-3">
                                            @categories?.FirstOrDefault(c => c.Id == item.CategoryId)?.Name
                                        </span>
                                    </td>
                                    <td>
                                        <div class="product-table__price">@item.Price.ToString("N0")₫</div>
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-action btn-action--edit" onclick="openModal(@item.ProductId)" title="Chỉnh sửa">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            <form id="deleteForm-@item.ProductId" asp-action="Delete" asp-route-id="@item.ProductId" method="post" style="display:none;"></form>
                                            <button type="button" class="btn btn-action btn-action--delete" 
                                                    onclick="confirmDelete(@item.ProductId, '@item.Name')" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-box-open d-block fs-1 mb-3 opacity-25"></i>
                                    Chưa có sản phẩm nào được tạo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Product Modal -->
<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="productModalLabel">Thêm sản phẩm mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Upsert" method="post" enctype="multipart/form-data">
                <div class="modal-body px-4 pb-4">
                    <input type="hidden" id="productId" name="ProductId" value="0" />
                    <input type="hidden" id="existingImageUrl" name="ImageUrls[0]" value="" />
                    
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label for="productName" class="form-label">Tên sản phẩm</label>
                            <input type="text" class="form-control rounded-3" id="productName" name="Name" required>
                        </div>
                        <div class="col-md-4">
                            <label for="productPrice" class="form-label">Giá bán (₫)</label>
                            <input type="number" class="form-control rounded-3" id="productPrice" name="Price" required min="0">
                        </div>
                        
                        <div class="col-md-12">
                            <label for="productCategory" class="form-label">Danh mục</label>
                            <select class="form-select rounded-3" id="productCategory" name="CategoryId" required>
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label for="productImageFile" class="form-label">Ảnh sản phẩm</label>
                            <div class="d-flex flex-column gap-3">
                                <div class="upload-box p-4 border-dashed border-2 rounded-4 text-center bg-light cursor-pointer" 
                                     onclick="document.getElementById('productImageFile').click()">
                                    <i class="fa-solid fa-cloud-arrow-up fs-2 text-primary mb-2"></i>
                                    <p class="mb-0 small text-muted">Bấm để chọn ảnh từ thiết bị</p>
                                    <input type="file" id="productImageFile" name="ImageFile" accept="image/*" class="d-none" onchange="previewImage(this)">
                                </div>
                                <div id="imagePreviewContainer" class="d-none">
                                    <p class="small text-muted mb-2">Xem trước:</p>
                                    <img id="imagePreview" src="" alt="Preview" class="rounded-4 shadow-sm" style="max-height: 150px; width: auto; object-fit: cover;">
                                </div>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label for="productDescription" class="form-label">Mô tả sản phẩm</label>
                            <textarea class="form-control rounded-3" id="productDescription" name="Description" rows="4"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-4 px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-4 px-4 shadow-sm">Lưu sản phẩm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .border-dashed { border-style: dashed !important; }
    .cursor-pointer { cursor: pointer; }
</style>

@section Scripts {
    <script>
        const modal = new bootstrap.Modal(document.getElementById('productModal'));
        const modalTitle = document.getElementById('productModalLabel');
        const productId = document.getElementById('productId');
        const existingImageUrl = document.getElementById('existingImageUrl');
        const productName = document.getElementById('productName');
        const productPrice = document.getElementById('productPrice');
        const productCategory = document.getElementById('productCategory');
        const productDescription = document.getElementById('productDescription');
        const imagePreviewContainer = document.getElementById('imagePreviewContainer');
        const imagePreview = document.getElementById('imagePreview');

        function openModal(id = 0) {
            // Reset modal state
            imagePreviewContainer.classList.add('d-none');
            imagePreview.src = '';
            document.getElementById('productImageFile').value = '';

            if (id === 0) {
                document.getElementById('productModalLabel').innerText = 'Thêm sản phẩm mới';
                productId.value = 0;
                existingImageUrl.value = '';
                productName.value = '';
                productPrice.value = '';
                productCategory.value = '';
                productDescription.value = '';
                modal.show();
            } else {
                fetch(`/Admin/Product/GetById/${id}`)
                    .then(res => res.json())
                    .then(data => {
                        document.getElementById('productModalLabel').innerText = 'Chỉnh sửa sản phẩm';
                        productId.value = data.productId;
                        productName.value = data.name;
                        productPrice.value = data.price;
                        productCategory.value = data.categoryId;
                        productDescription.value = data.description || '';
                        
                        // Show current image if exists
                        if (data.imageUrls && data.imageUrls.length > 0) {
                            existingImageUrl.value = data.imageUrls[0];
                            imagePreview.src = data.imageUrls[0];
                            imagePreviewContainer.classList.remove('d-none');
                        } else {
                            existingImageUrl.value = '';
                        }
                        
                        modal.show();
                    })
                    .catch(err => alert('Không thể tải thông tin sản phẩm.'));
            }
        }

        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    imagePreviewContainer.classList.remove('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xóa sản phẩm?',
                text: `Bạn có chắc chắn muốn xóa "${name}"? Thao tác này sẽ xóa vĩnh viễn dữ liệu.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Vâng, xóa đi!',
                cancelButtonText: 'Không, giữ lại',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(`deleteForm-${id}`).submit();
                }
            });
        }
    </script>
}
