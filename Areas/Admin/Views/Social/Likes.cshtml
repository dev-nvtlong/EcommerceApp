@model List<EcommerceApp.Application.DTOs.Social.LikeDto>
@{
    ViewData["Title"] = "Thống kê lượt thích";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0 fw-bold border-start border-4 border-success ps-3">Lượt thích bài viết</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Bài viết thích</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var like in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(like.UserAvatar) ? "https://ui-avatars.com/api/?name=" + like.UserFullName : like.UserAvatar)" 
                                         class="rounded-circle me-2" width="30" height="30">
                                    <span class="small fw-medium">@like.UserFullName</span>
                                </div>
                            </td>
                            <td><span class="small">@like.BlogPostTitle</span></td>
                            <td class="text-end pe-4 text-danger fs-5"><i class="fa-solid fa-heart"></i></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="3" class="text-center py-5 text-muted italic">Chưa có lượt thích nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
