@model List<EcommerceApp.Application.DTOs.Social.CommentDto>
@{
    ViewData["Title"] = "Quản lý bình luận";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3">
        <h5 class="mb-0 fw-bold border-start border-4 border-success ps-3">Danh sách bình luận</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Bài viết</th>
                        <th>Nội dung</th>
                        <th>Ngày gửi</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cmt in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(cmt.UserAvatar) ? "https://ui-avatars.com/api/?name=" + cmt.UserFullName : cmt.UserAvatar)" 
                                         class="rounded-circle me-2" width="30" height="30">
                                    <span class="small fw-medium">@cmt.UserFullName</span>
                                </div>
                            </td>
                            <td><span class="small text-truncate d-inline-block" style="max-width: 150px;">@cmt.BlogPostTitle</span></td>
                            <td class="small text-muted" style="max-width: 300px;">@cmt.Content</td>
                            <td class="small">@cmt.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end pe-4">
                                <button onclick="deleteCmt(@cmt.Id)" class="btn btn-sm btn-light-danger rounded-circle">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center py-5 text-muted italic">Chưa có bình luận nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteCmt(id) {
            Swal.fire({
                title: 'Xóa bình luận?',
                text: "Thao tác này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Social/DeleteComment/' + id, function(res) {
                        if (res.success) {
                            Swal.fire('Đã xóa!', '', 'success').then(() => location.reload());
                        }
                    });
                }
            });
        }
    </script>
}
