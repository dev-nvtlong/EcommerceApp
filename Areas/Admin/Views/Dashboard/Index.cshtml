@using EcommerceApp.Enums
@model EcommerceApp.Areas.Admin.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Thống kê tổng quan";
}

@section Styles {
    <link rel="stylesheet" href="~/Admin/css/dashboard.css" asp-append-version="true" />
}

<div class="mb-4">
    <div class="admin-layout__nav-label mb-3 mt-0">Thống kê Cửa hàng</div>
    <div class="dashboard-stats">
        <!-- Revenue -->
        <div class="stat-card">
            <div class="stat-icon icon-revenue"><i class="fa-solid fa-wallet"></i></div>
            <div>
                <div class="stat-label">Doanh thu</div>
                <div class="stat-value">@Model.TotalRevenue.ToString("N0")₫</div>
            </div>
        </div>
        <!-- Orders -->
        <div class="stat-card">
            <div class="stat-icon icon-orders"><i class="fa-solid fa-cart-shopping"></i></div>
            <div>
                <div class="stat-label">Đơn hàng</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
        </div>
        <!-- Customers -->
        <div class="stat-card">
            <div class="stat-icon icon-users"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="stat-label">Khách hàng</div>
                <div class="stat-value">@Model.TotalCustomers</div>
            </div>
        </div>
        <!-- Products -->
        <div class="stat-card">
            <div class="stat-icon icon-products"><i class="fa-solid fa-leaf"></i></div>
            <div>
                <div class="stat-label">Sản phẩm</div>
                <div class="stat-value">@Model.TotalProducts</div>
            </div>
        </div>
    </div>

    <div class="admin-layout__nav-label mb-3">Tương tác khách hàng</div>
    <div class="interaction-stats">
        <!-- Reviews -->
        <a asp-controller="Review" asp-action="Index" class="stat-card text-decoration-none shadow-hover">
            <div class="stat-icon icon-reviews"><i class="fa-solid fa-star"></i></div>
            <div>
                <div class="stat-label text-muted small">Đánh giá</div>
                <div class="stat-value text-dark fs-5">@Model.TotalReviews</div>
            </div>
        </a>
        <!-- Comments -->
        <a asp-controller="Social" asp-action="Comments" class="stat-card text-decoration-none shadow-hover">
            <div class="stat-icon icon-comments"><i class="fa-solid fa-comment-dots"></i></div>
            <div>
                <div class="stat-label text-muted small">Bình luận</div>
                <div class="stat-value text-dark fs-5">@Model.TotalComments</div>
            </div>
        </a>
        <!-- Likes -->
        <a asp-controller="Social" asp-action="Likes" class="stat-card text-decoration-none shadow-hover">
            <div class="stat-icon icon-likes"><i class="fa-solid fa-heart"></i></div>
            <div>
                <div class="stat-label text-muted small">Lượt thích</div>
                <div class="stat-value text-dark fs-5">@Model.TotalLikes</div>
            </div>
        </a>
    </div>
</div>

<div class="dashboard-grid">
    <!-- Recent Orders -->
    <div class="dashboard-panel">
        <div class="panel-header">
            <h2 class="panel-title">Đơn hàng vừa đặt</h2>
            <a asp-controller="Order" asp-action="Index" class="btn btn-sm btn-light rounded-pill px-3 fw-bold ps-2">Xem tất cả</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle border-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="border-0 ps-3">Mã đơn</th>
                        <th class="border-0">Khách hàng</th>
                        <th class="border-0">Tổng tiền</th>
                        <th class="border-0">Trạng thái</th>
                        <th class="border-0 text-end pe-3">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">#@order.Id</td>
                            <td>
                                <div class="small fw-medium">@order.CustomerName</div>
                                <div class="text-muted" style="font-size: 11px;">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </td>
                            <td class="fw-bold text-success">@order.TotalAmount.ToString("N0")₫</td>
                            <td>
                                <span class="badge bg-@(order.Status == OrderStatus.Completed ? "success" : order.Status == OrderStatus.Pending ? "warning" : "info")-subtle text-@(order.Status == OrderStatus.Completed ? "success" : order.Status == OrderStatus.Pending ? "warning" : "info") rounded-pill px-3">
                                    @order.Status.ToString()
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id" class="btn btn-icon btn-sm btn-light rounded-circle"><i class="fa-solid fa-eye"></i></a>
                            </td>
                        </tr>
                    }
                    @if (!Model.RecentOrders.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có đơn hàng nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Notifications -->
    <div class="dashboard-panel">
        <div class="panel-header">
            <h2 class="panel-title">Thông báo mới nhất</h2>
            <div id="quickBadge" class="badge bg-danger rounded-pill">@Model.RecentNotifications.Count(n => !n.IsRead) mới</div>
        </div>
        <div class="recent-list">
            @foreach (var note in Model.RecentNotifications)
            {
                <div class="notification-brief @(note.IsRead ? "" : "notification-brief--unread") cursor-pointer" onclick="location.href='@note.RedirectUrl'">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-bold small text-dark">@note.Title</span>
                        <span class="text-muted" style="font-size: 10px;">@note.CreatedAt.ToString("HH:mm")</span>
                    </div>
                    <div class="text-muted small text-truncate">@note.Message</div>
                </div>
            }
            @if (!Model.RecentNotifications.Any())
            {
                <div class="text-center py-4 text-muted small">Không có thông báo mới</div>
            }
        </div>
    </div>
</div>