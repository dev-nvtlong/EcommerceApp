<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ecommerce Admin</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/Admin/css/admin-layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        .swal2-popup { font-family: 'Outfit', sans-serif !important; border-radius: 20px !important; }
        .swal2-confirm { border-radius: 12px !important; padding: 12px 30px !important; font-weight: 500 !important; }
        .swal2-cancel { border-radius: 12px !important; padding: 12px 30px !important; font-weight: 500 !important; }
    </style>
</head>
<body class="admin-body">
    
    <div class="admin-layout">
        <!-- Mobile Overlay -->
        <div class="admin-layout__overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <aside class="admin-layout__sidebar" id="sidebar">
            <div class="admin-layout__brand">
                <i class="fa-solid fa-bag-shopping admin-layout__brand-icon"></i>
                <span class="admin-layout__brand-text">E-Shop Admin</span>
            </div>
            
            <nav class="admin-layout__nav">
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="fa-solid fa-chart-line admin-layout__nav-icon"></i>
                    <span>Bảng điều khiển</span>
                </a>
                
                <div class="admin-layout__nav-label">Quản lý cửa hàng</div>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Category" asp-action="Index">
                    <i class="fa-solid fa-list admin-layout__nav-icon"></i>
                    <span>Danh mục</span>
                </a>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Product" asp-action="Index">
                    <i class="fa-solid fa-box admin-layout__nav-icon"></i>
                    <span>Sản phẩm</span>
                </a>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Order" asp-action="Index">
                    <i class="fa-solid fa-cart-shopping admin-layout__nav-icon"></i>
                    <span>Đơn hàng</span>
                </a>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="User" asp-action="Index">
                    <i class="fa-solid fa-users admin-layout__nav-icon"></i>
                    <span>Người dùng</span>
                </a>

                <div class="admin-layout__nav-label">Nội dung & Phản hồi</div>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Blog" asp-action="Index">
                    <i class="fa-solid fa-newspaper admin-layout__nav-icon"></i>
                    <span>Bài viết</span>
                </a>

                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Comments" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Social" asp-action="Comments">
                    <i class="fa-solid fa-comment-dots admin-layout__nav-icon"></i>
                    <span>Bình luận</span>
                </a>

                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Likes" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Social" asp-action="Likes">
                    <i class="fa-solid fa-heart admin-layout__nav-icon"></i>
                    <span>Lượt thích</span>
                </a>
                
                <a class="admin-layout__nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Review" ? "admin-layout__nav-link--active" : "")" 
                   asp-area="Admin" asp-controller="Review" asp-action="Index">
                    <i class="fa-solid fa-star admin-layout__nav-icon"></i>
                    <span>Đánh giá</span>
                </a>
                
                <div class="admin-layout__nav-label">Cấu hình</div>
                <a class="admin-layout__nav-link" href="#">
                    <i class="fa-solid fa-gear admin-layout__nav-icon"></i>
                    <span>Cài đặt hệ thống</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content Area -->
        <div class="admin-layout__wrapper" id="contentWrapper">
            <!-- Header -->
            <header class="admin-layout__header">
                <div class="admin-layout__header-left">
                    <button class="admin-layout__toggle-btn" id="sidebarToggle">
                        <i class="fa-solid fa-bars-staggered"></i>
                    </button>
                    <h1 class="admin-layout__page-title">@ViewData["Title"]</h1>
                </div>
                
                <div class="admin-layout__header-right">
                    <div class="admin-layout__search">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Tìm kiếm nhanh...">
                    </div>
                    
                    <div class="dropdown admin-layout__notification">
                        <a href="#" class="text-decoration-none position-relative" data-bs-toggle="dropdown" id="notificationDropdown">
                            <i class="fa-regular fa-bell fs-5"></i>
                            <span class="admin-layout__notification-badge badge bg-danger rounded-circle d-none shadow-sm" id="notificationBadge">0</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end border-0 shadow-lg ms-3 p-0" aria-labelledby="notificationDropdown" style="width: 350px; min-width: 350px; max-width: 350px; overflow: hidden;">
                            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                                <h6 class="mb-0 fw-bold">Thông báo</h6>
                                <button class="btn btn-sm btn-link text-primary text-decoration-none p-0 small fw-bold" onclick="markAllAsRead(event)">Đọc tất cả</button>
                            </div>
                            <div id="notificationList" class="p-0" style="max-height: 400px; overflow-y: auto; overflow-x: hidden;">
                                <div class="p-4 text-center text-muted small">Đang tải thông báo...</div>
                            </div>
                            <div class="p-2 border-top text-center bg-light">
                                <a href="#" class="small text-muted text-decoration-none fw-medium">Xem tất cả thông báo</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="dropdown admin-layout__user">
                        <a href="#" class="text-decoration-none d-flex align-items-center gap-2" data-bs-toggle="dropdown" id="userDropdown">
                            <img src="https://ui-avatars.com/api/?name=Admin&background=6366f1&color=fff" alt="Admin" class="admin-layout__user-avatar">
                            <span class="admin-layout__user-name">Quản trị viên</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3" aria-labelledby="userDropdown">
                            <li><h6 class="dropdown-header">Tài khoản Admin</h6></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="Admin" asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm">
                                    <button type="submit" class="dropdown-item text-danger d-flex align-items-center gap-2 py-2">
                                        <i class="fa-solid fa-right-from-bracket"></i>
                                        <span>Đăng xuất</span>
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Main Body -->
            <main class="admin-layout__main">
                <div class="admin-layout__container">
                    @RenderBody()
                </div>
            </main>
            
            <footer class="admin-layout__footer">
                <p>&copy; @DateTime.Now.Year EcommerceApp - Modern Admin Dashboard</p>
            </footer>
        </div>
    </div>
    
    <!-- Global Modal cho Order Details -->
    <div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true" style="z-index: 1060;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4" id="orderModalContent">
                <div class="modal-body text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Đang tải...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            const $sidebar = $('#sidebar');
            const $wrapper = $('#contentWrapper');
            const $overlay = $('#sidebarOverlay');

            $('#sidebarToggle, #sidebarOverlay').click(function() {
                $sidebar.toggleClass('admin-layout__sidebar--collapsed');
                $wrapper.toggleClass('admin-layout__wrapper--expanded');
                
                if ($(window).width() <= 1024) {
                    $overlay.toggleClass('admin-layout__overlay--visible');
                    $('body').toggleClass('overflow-hidden');
                }
            });

            // Handle window resize
            $(window).resize(function() {
                if ($(window).width() > 1024) {
                    $overlay.removeClass('admin-layout__overlay--visible');
                    $('body').removeClass('overflow-hidden');
                }
            });

            // Notification Logic
            function updateNotificationBadge() {
                $.get('/Admin/Notification/GetRecent', function(res) {
                    if (res.unreadCount > 0) {
                        $('#notificationBadge').text(res.unreadCount).removeClass('d-none');
                    } else {
                        $('#notificationBadge').addClass('d-none');
                    }
                });
            }

            window.loadNotifications = function() {
                const $list = $('#notificationList');
                $.get('/Admin/Notification/GetRecent', function(res) {
                    if (!res.notifications || res.notifications.length === 0) {
                        $list.html('<div class="p-4 text-center text-muted small">Không có thông báo mới</div>');
                        return;
                    }

                    let html = '';
                    res.notifications.forEach(n => {
                        const iconClass = n.type === 0 ? 'order' : n.type === 1 ? 'comment' : n.type === 2 ? 'like' : n.type === 3 ? 'chat' : 'review';
                        const icon = n.type === 0 ? 'fa-cart-shopping' : n.type === 1 ? 'fa-comment' : n.type === 2 ? 'fa-heart' : n.type === 3 ? 'fa-message' : 'fa-star';
                        const unreadClass = n.isRead ? '' : 'notification-item--unread';
                        const date = new Date(n.createdAt).toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' });

                        html += `
                            <div class="notification-item p-3 border-bottom d-flex gap-3 ${unreadClass}" onclick="handleNotificationClick(${n.id}, '${n.redirectUrl}')">
                                <div class="notification-icon notification-icon--${iconClass}">
                                    <i class="fa-solid ${icon}"></i>
                                </div>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-bold text-dark small text-truncate">${n.title}</div>
                                    <div class="text-muted small text-truncate">${n.message}</div>
                                    <div class="text-muted italic mt-1" style="font-size: 10px;">${date}</div>
                                </div>
                            </div>
                        `;
                    });
                    $list.html(html);
                });
            };

            window.handleNotificationClick = function(id, url) {
                $.post('/Admin/Notification/MarkAsRead/' + id, function() {
                    if (url) {
                        const orderIdMatch = url.match(/\/Order\/Details\/(\d+)/i);
                        if (orderIdMatch && orderIdMatch[1]) {
                            window.loadGlobalOrderDetails(orderIdMatch[1]);
                        } else {
                            window.location.href = url;
                        }
                    }
                });
            };

            window.loadGlobalOrderDetails = function(id) {
                const $modal = $('#orderModal');
                const $modalContent = $('#orderModalContent');
                
                $modalContent.html(`
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                `);
                $modal.modal('show');

                $.ajax({
                    url: '/Admin/Order/Details',
                    type: 'GET',
                    data: { id: id },
                    success: function (data) {
                        $modalContent.html(data);
                    },
                    error: function (xhr) {
                        $modalContent.html(`
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold text-danger">Lỗi</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body p-4 text-center">
                                <p class="mb-0 text-muted">${xhr.responseText || 'Đã có lỗi xảy ra khi tải dữ liệu.'}</p>
                            </div>
                            <div class="modal-footer border-0 pt-0 text-center">
                                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                            </div>
                        `);
                    }
                });
            };

            window.markAllAsRead = function(e) {
                if (e) e.stopPropagation();
                $.post('/Admin/Notification/MarkAllAsRead', function() {
                    updateNotificationBadge();
                    loadNotifications();
                });
            };

            $('#notificationDropdown').on('show.bs.dropdown', function () {
                loadNotifications();
            });

            // Initial badge update
            updateNotificationBadge();
            // Poll every 1 minute
            setInterval(updateNotificationBadge, 60000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
