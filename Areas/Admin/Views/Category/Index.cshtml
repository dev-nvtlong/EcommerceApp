@model IEnumerable<EcommerceApp.Application.DTOs.Category.CategoryDto>
@{
    ViewData["Title"] = "Quản lý danh mục";
}


<style>
    .category-page {
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .category-page__title {
        font-weight: 700;
        color: var(--text-main);
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .category-page__card {
        transition: var(--transition);
        overflow: hidden;
    }

    .category-page__card:hover {
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
    }

    .category-table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.8px;
        color: var(--text-muted);
        border-top: none;
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .category-table tbody tr {
        transition: var(--transition);
    }

    .category-table tbody tr:hover {
        background-color: rgba(99, 102, 241, 0.02);
    }

    .category-table__id {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 600;
    }

    .category-table__name {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-main);
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 10px;
        transition: var(--transition);
        background: none;
    }

    .btn-action--edit {
        color: var(--primary-color);
        background-color: rgba(99, 102, 241, 0.1);
    }

    .btn-action--edit:hover {
        background-color: var(--primary-color);
        color: white;
    }

    .btn-action--delete {
        color: #ef4444;
        background-color: rgba(239, 68, 68, 0.1);
    }

    .btn-action--delete:hover {
        background-color: #ef4444;
        color: white;
    }

    /* Modal Styling */
    .modal-content {
        border: none;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .modal-header {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    .form-label {
        font-size: 13px;
        color: var(--text-muted);
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-control {
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
        transition: var(--transition);
    }

    .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
</style>

<div class="category-page">
    <div class="category-page__header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="category-page__title">Danh mục sản phẩm</h2>
            <p class="text-muted">Quản lý các danh mục chính và phụ của hệ thống cửa hàng.</p>
        </div>
        <button class="btn btn-primary d-flex align-items-center gap-2" onclick="openModal()">
            <i class="fa-solid fa-plus"></i>
            Thêm mới
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="category-page__card card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 category-table">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3" style="width: 80px;">ID</th>
                            <th class="py-3">Tên danh mục</th>
                            <th class="py-3 text-end px-4" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <span class="category-table__id text-muted">#@item.Id</span>
                                    </td>
                                    <td>
                                        <div class="category-table__name">@item.Name</div>
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="d-flex justify-content-end gap-2 text-nowrap">
                                            <button class="btn btn-action btn-action--edit" onclick="openModal(@item.Id)" title="Chỉnh sửa">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            <form id="deleteForm-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;"></form>
                                            <button type="button" class="btn btn-action btn-action--delete" 
                                                    onclick="confirmDelete(@item.Id, '@item.Name')" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-box-open d-block fs-1 mb-3 opacity-25"></i>
                                    Chưa có danh mục nào được tạo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Category Modal -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-bottom-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="categoryModalLabel">Thêm danh mục mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Upsert" method="post">
                <div class="modal-body px-4 pb-4">
                    <input type="hidden" id="categoryId" name="Id" value="0" />
                    <div class="mb-3">
                        <label for="categoryName" class="form-label fw-medium">Tên danh mục</label>
                        <input type="text" class="form-control rounded-3 py-2" id="categoryName" name="Name" required placeholder="VD: Điện thoại, Laptop...">
                    </div>
                </div>
                <div class="modal-footer border-top-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary rounded-3 px-4 shadow-sm" id="btnSave">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const modal = new bootstrap.Modal(document.getElementById('categoryModal'));
        const modalTitle = document.getElementById('categoryModalLabel');
        const categoryId = document.getElementById('categoryId');
        const categoryName = document.getElementById('categoryName');

        function openModal(id = 0) {
            if (id === 0) {
                // Add new
                modalTitle.innerText = 'Thêm danh mục mới';
                categoryId.value = 0;
                categoryName.value = '';
                modal.show();
            } else {
                // Edit - fetch data
                fetch(`/Admin/Category/GetById/${id}`)
                    .then(response => response.json())
                    .then(data => {
                        modalTitle.innerText = 'Chỉnh sửa danh mục';
                        categoryId.value = data.id;
                        categoryName.value = data.name;
                        modal.show();
                    })
                    .catch(err => {
                        console.error('Lỗi khi lấy dữ liệu danh mục:', err);
                        alert('Không thể tải thông tin danh mục. Vui lòng thử lại.');
                    });
            }
        }

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xóa danh mục?',
                text: `Bạn có chắc chắn muốn xóa danh mục "${name}"? Hành động này không thể hoàn tác.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Đúng, xóa nó!',
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById(`deleteForm-${id}`).submit();
                }
            });
        }
    </script>
}
