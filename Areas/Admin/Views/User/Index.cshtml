@model IEnumerable<EcommerceApp.Application.DTOs.Account.UserDto>
@using EcommerceApp.Enums
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold mb-0">Quản lý khách hàng</h1>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Khách hàng</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                    <th>Ngày đăng ký</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(user.Avatar) ? "https://ui-avatars.com/api/?name=" + user.FullName + "&background=6366f1&color=fff" : user.Avatar)" 
                                     class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;">
                                <div>
                                    <div class="fw-bold text-dark">@user.FullName</div>
                                    <div class="text-muted small">@@@user.UserName</div>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td>@(string.IsNullOrEmpty(user.PhoneNumber) ? "--" : user.PhoneNumber)</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge bg-light text-primary border border-primary-subtle rounded-pill px-3 me-1">@role</span>
                            }
                        </td>
                        <td class="text-muted small">@user.CreateAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end pe-4">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light rounded-circle shadow-none" type="button" data-bs-toggle="dropdown">
                                    <i class="fa-solid fa-ellipsis-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-3">
                                    <li><button class="dropdown-item py-2 view-user-details" data-id="@user.Id"><i class="fa-solid fa-eye me-2 text-primary"></i> Xem chi tiết</button></li>
                                    @if (!user.Roles.Contains("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?')">
                                                <button type="submit" class="dropdown-item py-2 text-danger"><i class="fa-solid fa-trash-can me-2"></i> Xóa tài khoản</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4" id="userModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Đang tải...</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const $modal = $('#userModal');
            const $modalContent = $('#userModalContent');

            $('.view-user-details').on('click', function () {
                const id = $(this).data('id');
                loadModalContent('@Url.Action("Details")', id);
            });

            function loadModalContent(url, id) {
                $modalContent.html(`
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                `);
                $modal.modal('show');

                $.ajax({
                    url: url,
                    type: 'GET',
                    data: { id: id },
                    success: function (data) {
                        $modalContent.html(data);
                    },
                    error: function (xhr) {
                        $modalContent.html(`
                            <div class="modal-header border-0 pb-0">
                                <h5 class="modal-title fw-bold text-danger">Lỗi</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body p-4 text-center">
                                <p class="mb-0 text-muted">${xhr.responseText || 'Đã có lỗi xảy ra khi tải dữ liệu.'}</p>
                            </div>
                            <div class="modal-footer border-0 pt-0">
                                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                            </div>
                        `);
                    }
                });
            }
        });
    </script>
}
