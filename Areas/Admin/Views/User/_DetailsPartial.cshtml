@model EcommerceApp.Application.DTOs.Account.UserDto
@using EcommerceApp.Enums

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title fw-bold" id="userModalLabel">Chi tiết khách hàng: @Model.FullName</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body p-4 p-md-5">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="text-center">
                <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "https://ui-avatars.com/api/?name=" + Model.FullName + "&background=6366f1&color=fff&size=256" : Model.Avatar)" 
                     class="rounded-circle border border-4 border-white shadow-sm mx-auto mb-4" 
                     style="width: 150px; height: 150px; object-fit: cover;">
                
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted mb-4 small">@@@Model.UserName</p>
                
                <div class="d-flex justify-content-center gap-2 mb-4 flex-wrap">
                    @foreach (var role in Model.Roles)
                    {
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-2">@role</span>
                    }
                </div>
                <hr class="opacity-10 my-4">
                <div class="text-start">
                    <div class="mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Ngày đăng ký</label>
                        <div class="fw-semibold">@Model.CreateAt?.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border shadow-none rounded-4 p-4 mb-0">
                <h6 class="fw-bold mb-4 text-primary"><i class="fa-solid fa-id-card me-2"></i>Thông tin cá nhân</h6>
                
                <div class="row g-4">
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Họ và tên</label>
                        <div class="fw-semibold">@Model.FullName</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Email</label>
                        <div class="fw-semibold">@Model.Email</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Số điện thoại</label>
                        <div class="fw-semibold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "--" : Model.PhoneNumber)</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Ngày sinh</label>
                        <div class="fw-semibold">@(Model.DateOfBirth?.ToString("dd/MM/yyyy") ?? "--")</div>
                    </div>
                    <div class="col-md-6 mb-0">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1">Giới tính</label>
                        <div class="fw-semibold">
                            @(Model.Gender switch {
                                GenderType.Male => "Nam",
                                GenderType.Female => "Nữ",
                                GenderType.Other => "Khác",
                                _ => "Chưa xác định"
                            })
                        </div>
                    </div>
                    <div class="col-12 mb-0">
                        <label class="text-muted small fw-bold text-uppercase d-block mb-1 mt-3">Địa chỉ</label>
                        <div class="text-dark bg-light p-3 rounded-3 mt-2" style="font-size: 0.9rem;">
                            @(string.IsNullOrEmpty(Model.Address) ? "Chưa cung cấp địa chỉ." : Model.Address)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-footer border-0 pt-0">
    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
</div>
