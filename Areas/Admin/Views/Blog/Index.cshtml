@using EcommerceApp.Enums
@model IEnumerable<EcommerceApp.Application.DTOs.Blog.BlogPostDto>
@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 text-success"><i class="fa-solid fa-newspaper me-2"></i>Quản lý bài viết</h1>
            <p class="text-muted mb-0">Danh sách các tin tức và bài blog của hệ thống.</p>
        </div>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Viết bài mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Bài viết</th>
                            <th>Danh mục</th>
                            <th>Tác giả</th>
                            <th>Ngày viết</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.Thumbnail))
                                        {
                                            <img src="@item.Thumbnail" class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                        }
                                        else
                                        {
                                            <div class="rounded-3 me-3 bg-light d-flex align-items-center justify-content-center text-muted" style="width: 60px; height: 60px;">
                                                <i class="fa-solid fa-image"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-bold text-dark">@item.Title</div>
                                            <div class="small text-muted">
                                                <i class="fa-solid fa-heart me-1 text-danger"></i> @item.LikeCount
                                                @if (!string.IsNullOrEmpty(item.Tags))
                                                {
                                                    <span class="ms-2"><i class="fa-solid fa-tag me-1 text-primary"></i> @item.Tags.Split(',').Length thẻ</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.Category == BlogCategory.Sales)
                                    {
                                        <span class="badge bg-success text-white rounded-pill px-3">Bài viết</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary text-white rounded-pill px-3">Kinh nghiệm</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark rounded-pill px-3">@item.AuthorName</span>
                                </td>
                                <td class="text-muted italic">@item.CreatedAt?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.IsPublished)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2 border-0">Công khai</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2 border-0">Nháp</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-icon btn-light rounded-circle shadow-none border-0" data-bs-toggle="dropdown">
                                            <i class="fa-solid fa-ellipsis-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-3">
                                            <li><a class="dropdown-item py-2" asp-action="Edit" asp-route-id="@item.Id"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i> Chỉnh sửa</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><button class="dropdown-item py-2 text-danger" onclick="deletePost(@item.Id)"><i class="fa-solid fa-trash-can me-2"></i> Xóa bài</button></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deletePost(id) {
            Swal.fire({
                title: 'Xóa bài viết?',
                text: "Bạn sẽ không thể khôi phục lại dữ liệu này!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#2d6a4f',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Blog/Delete/' + id, function (data) {
                        if (data.success) {
                            Swal.fire('Đã xóa!', 'Bài viết đã được gỡ bỏ.', 'success')
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Lỗi!', 'Có lỗi xảy ra khi xóa.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
