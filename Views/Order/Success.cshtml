@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container py-5 text-center">
    <div class="py-5">
        <div class="mb-4">
            <i class="fa-solid fa-circle-check text-success display-1"></i>
        </div>
        <h1 class="fw-bold mb-3">Đặt hàng thành công!</h1>
        <p class="text-muted mb-5">
            Cảm ơn bạn đã tin tưởng và chọn <strong>Green Life</strong>.<br>
            Đơn hàng của bạn <strong>#@ViewBag.OrderId</strong> đã được ghi nhận và đang chờ xử lý.
        </p>

        <div class="d-grid d-sm-flex justify-content-center gap-3">
            <a asp-controller="Order" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow">
                Xem lịch sử mua hàng
            </a>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-primary rounded-pill px-5 py-3 fw-bold">
                Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>
