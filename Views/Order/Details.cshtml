@model EcommerceApp.Application.DTOs.Order.OrderDto
@using EcommerceApp.Enums
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<div class="py-5 bg-white border-bottom">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="fw-bold mb-0">Đơn hàng #@Model.Id</h1>
                <p class="text-muted mb-0 mt-2">Đặt ngày @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
            </a>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-light border-0 py-3 px-4">
                    <h5 class="mb-0 fw-bold">Danh sách sản phẩm</h5>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end pe-4">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Details)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div>
                                                <div class="fw-bold text-dark">@item.Product.Name</div>
                                                <div class="text-muted small">@item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">x @item.Quantity</td>
                                    <td class="text-end pe-4 fw-bold">@item.SubTotal.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <h5 class="fw-bold mb-4">Trạng thái đơn hàng</h5>
                <div class="d-flex align-items-center mb-4">
                    @switch (Model.Status)
                    {
                        case OrderStatus.Pending:
                            <div class="rounded-circle bg-warning p-3 me-3 text-white"><i class="fa-solid fa-clock"></i></div>
                            <div>
                                <div class="fw-bold text-warning">Chờ xử lý</div>
                                <div class="text-muted small">Đơn hàng đang chờ quản trị viên xác nhận.</div>
                            </div>
                            break;
                        case OrderStatus.Confirmed:
                            <div class="rounded-circle bg-info p-3 me-3 text-white"><i class="fa-solid fa-check"></i></div>
                            <div>
                                <div class="fw-bold text-info">Đã xác nhận</div>
                                <div class="text-muted small">Đơn hàng đã được xác nhận thành công.</div>
                            </div>
                            break;
                        case OrderStatus.Shipping:
                            <div class="rounded-circle bg-primary p-3 me-3 text-white"><i class="fa-solid fa-truck"></i></div>
                            <div>
                                <div class="fw-bold text-primary">Đang giao</div>
                                <div class="text-muted small">Đơn hàng đang trên đường đến với bạn.</div>
                            </div>
                            break;
                        case OrderStatus.Completed:
                            <div class="rounded-circle bg-success p-3 me-3 text-white"><i class="fa-solid fa-house-chimney-check"></i></div>
                            <div>
                                <div class="fw-bold text-success">Hoàn thành</div>
                                <div class="text-muted small">Đơn hàng đã giao thành công.</div>
                            </div>
                            break;
                        case OrderStatus.Cancelled:
                            <div class="rounded-circle bg-danger p-3 me-3 text-white"><i class="fa-solid fa-xmark"></i></div>
                            <div>
                                <div class="fw-bold text-danger">Đã hủy</div>
                                <div class="text-muted small">Đơn hàng hiện đã bị hủy.</div>
                            </div>
                            break;
                    }
                </div>
                
                <hr class="opacity-25 my-4">
                
                <h5 class="fw-bold mb-3">Tóm tắt thanh toán</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Phương thức</span>
                    <span class="fw-semibold">@(Model.PaymentMethod == PaymentMethod.Banking ? "Chuyển khoản" : "Tiền mặt")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính</span>
                    <span>@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Giao hàng</span>
                    <span class="text-success fw-bold">Miễn phí</span>
                </div>
                <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                    <span class="fw-bold h5 mb-0">Tổng cộng</span>
                    <span class="fw-bold h5 mb-0 text-primary">@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm rounded-4 p-4 bg-primary text-white">
                <h5 class="fw-bold mb-3">Bạn cần trợ giúp?</h5>
                <p class="small mb-3 opacity-75">Nếu có bất kỳ thắc mắc nào về đơn hàng, vui lòng liên hệ với chúng tôi.</p>
                <div class="d-grid">
                    <a href="tel:0123456789" class="btn btn-light rounded-pill fw-bold text-primary">
                        <i class="fa-solid fa-phone me-2"></i> Gọi ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
