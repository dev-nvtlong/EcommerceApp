@model IEnumerable<EcommerceApp.Application.DTOs.Order.OrderDto>
@using EcommerceApp.Enums
@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="py-5 bg-white border-bottom">
    <div class="container">
        <h1 class="fw-bold mb-0">Đơn hàng của tôi</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 mt-2">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Lịch sử đơn hàng</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="fa-solid fa-box-open text-muted opacity-25 display-1"></i>
            </div>
            <h3 class="fw-bold text-muted">Bạn chưa có đơn hàng nào</h3>
            <p class="text-muted mb-4">Mua sắm ngay để bắt đầu hành trình xanh cùng Green Life!</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 fw-bold">
                Khám phá cửa hàng
            </a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã đơn hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.OrderByDescending(o => o.OrderDate))
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@order.Id</td>
                                <td class="text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-primary">@order.TotalAmount.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                                <td>
                                    <span class="badge bg-light @(order.PaymentMethod == PaymentMethod.Banking ? "text-info" : "text-dark") border">
                                        @(order.PaymentMethod == PaymentMethod.Banking ? "Chuyển khoản" : "Tiền mặt")
                                    </span>
                                </td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case OrderStatus.Pending:
                                            <span class="badge bg-warning-subtle text-warning border-warning border px-3 rounded-pill">Chờ xử lý</span>
                                            break;
                                        case OrderStatus.Confirmed:
                                            <span class="badge bg-info-subtle text-info border-info border px-3 rounded-pill">Đã xác nhận</span>
                                            break;
                                        case OrderStatus.Shipping:
                                            <span class="badge bg-primary-subtle text-primary border-primary border px-3 rounded-pill">Đang giao</span>
                                            break;
                                        case OrderStatus.Completed:
                                            <span class="badge bg-success-subtle text-success border-success border px-3 rounded-pill">Hoàn thành</span>
                                            break;
                                        case OrderStatus.Cancelled:
                                            <span class="badge bg-danger-subtle text-danger border-danger border px-3 rounded-pill">Đã hủy</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fa-solid fa-eye me-1"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
