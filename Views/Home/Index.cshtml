@{
    ViewData["Title"] = "Green Life - Cửa Hàng Cây Cảnh Cao Cấp";
    var categories = ViewBag.Categories as List<EcommerceApp.Application.DTOs.Category.CategoryDto>;
    var products = ViewBag.FeaturedProducts as List<EcommerceApp.Application.DTOs.Product.ProductDto>;
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<!-- ============================================
     HERO SECTION
     ============================================ -->
<section class="home-hero">
    <div class="home-hero__decor-circle home-hero__decor-circle--1"></div>
    <div class="home-hero__decor-circle home-hero__decor-circle--2"></div>
    <div class="home-hero__decor-circle home-hero__decor-circle--3"></div>

    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="home-hero__badge">🌿 Chất lượng từ thiên nhiên</div>
                <h1 class="home-hero__title">Biến Không Gian Của Bạn Thành <span>Tuyệt Tác Xanh</span></h1>
                <p class="home-hero__desc">
                    Khám phá bộ sưu tập cây cảnh nghệ thuật và giải pháp trang trí không gian sống chuyên nghiệp. Chăm sóc tận tâm, giao hàng hỏa tốc.
                </p>
                <div class="home-hero__actions">
                    <a asp-controller="Shop" asp-action="Index" class="home-hero__btn home-hero__btn--primary">
                        <i class="fa-solid fa-bag-shopping"></i> Bắt đầu mua sắm
                    </a>
                    <a href="#featured" class="home-hero__btn home-hero__btn--outline">
                        <i class="fa-solid fa-fire-flame-curved"></i> Xem xu hướng
                    </a>
                </div>
                <div class="home-hero__social">
                    <div class="home-hero__avatars">
                        <img src="https://i.pravatar.cc/40?img=1" alt="Customer">
                        <img src="https://i.pravatar.cc/40?img=2" alt="Customer">
                        <img src="https://i.pravatar.cc/40?img=3" alt="Customer">
                    </div>
                    <div class="home-hero__social-text">
                        <strong>5,000+ Khách hàng</strong>
                        <span>Đã tin dùng sản phẩm của chúng tôi</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="home-hero__images">
                    <img src="/images/hero-main.png"
                         alt="Featured Plant" class="home-hero__img-main">
                    <img src="/images/hero-secondary.png"
                         alt="Plants Collection" class="home-hero__img-secondary">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================
     FEATURES SECTION
     ============================================ -->
<section class="home-features">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="home-features__card reveal reveal-delay-1">
                    <div class="home-features__icon"><i class="fa-solid fa-truck-fast"></i></div>
                    <h5>Giao hàng miễn phí</h5>
                    <p>Cho mọi đơn hàng trên 500k tại khu vực nội thành.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="home-features__card reveal reveal-delay-2">
                    <div class="home-features__icon"><i class="fa-solid fa-shield-halved"></i></div>
                    <h5>Bảo hành 30 ngày</h5>
                    <p>Cam kết 1 đổi 1 nếu cây có vấn đề trong tháng đầu.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="home-features__card reveal reveal-delay-3">
                    <div class="home-features__icon"><i class="fa-solid fa-headset"></i></div>
                    <h5>Hỗ trợ 24/7</h5>
                    <p>Đội ngũ chuyên gia sẵn sàng tư vấn cách chăm sóc.</p>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="home-features__card reveal reveal-delay-4">
                    <div class="home-features__icon"><i class="fa-solid fa-leaf"></i></div>
                    <h5>Cây tuyển chọn</h5>
                    <p>Mọi cây đều được kiểm tra kỹ lưỡng trước khi đóng gói.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================
     CATEGORIES SECTION
     ============================================ -->
<section class="home-categories">
    <div class="container">
        <div class="home-section-header reveal">
            <h2>Danh mục nổi bật</h2>
            <p>Lựa chọn phong cách xanh phù hợp với bạn</p>
        </div>
        <div class="row g-4">
            @if (categories != null && categories.Any())
            {
                var catImages = new string[] {
                    "https://images.unsplash.com/photo-1545241047-6083a3684587?q=80&w=600&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?q=80&w=600&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1512428813833-df52167ad833?q=80&w=600&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1597055181300-e3633a2b7519?q=80&w=600&auto=format&fit=crop"
                };
                int i = 0;
                foreach (var cat in categories)
                {
                    <div class="col-6 col-lg-3 reveal reveal-delay-@(i + 1 > 4 ? 4 : i + 1)">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@cat.Id" class="text-decoration-none">
                            <div class="home-categories__card">
                                <img src="@(i < catImages.Length ? catImages[i++] : catImages[0])" alt="@cat.Name">
                                <div class="home-categories__overlay">
                                    <h4>@cat.Name</h4>
                                    <span>Xem thêm <i class="fa-solid fa-arrow-right ms-1"></i></span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- ============================================
     FEATURED PRODUCTS SECTION
     ============================================ -->
<section id="featured" class="home-products">
    <div class="container">
        <div class="home-section-header home-section-header--split reveal">
            <div>
                <h2>Sản phẩm nổi bật</h2>
                <p>Những cây cảnh được yêu thích nhất tại Green Life</p>
            </div>
            <a asp-controller="Shop" asp-action="Index" class="home-section-link">
                Xem tất cả <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
        <div class="row g-4">
            @if (products != null && products.Any())
            {
                int pIdx = 0;
                foreach (var product in products)
                {
                    pIdx++;
                    <div class="col-6 col-lg-3 reveal reveal-delay-@(pIdx > 4 ? 4 : pIdx)">
                        <div class="home-products__card">
                            <div class="home-products__img-wrap">
                                @if (product.IsFeatured)
                                {
                                    <span class="home-products__badge">Nổi bật</span>
                                }
                                <a asp-controller="Shop" asp-action="Detail" asp-route-id="@product.ProductId">
                                    <img src="@(product.ImageUrls?.FirstOrDefault() ?? "/images/no-image.png")" alt="@product.Name">
                                </a>
                                <div class="home-products__quick-actions">
                                    <button class="home-products__quick-btn" onclick="addToCart('@product.ProductId')" title="Thêm vào giỏ">
                                        <i class="fa-solid fa-cart-plus"></i>
                                    </button>
                                    <a asp-controller="Shop" asp-action="Detail" asp-route-id="@product.ProductId" class="home-products__quick-btn" title="Xem chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="home-products__info">
                                <a asp-controller="Shop" asp-action="Detail" asp-route-id="@product.ProductId" class="home-products__name">
                                    @product.Name
                                </a>
                                <div class="home-products__rating">
                                    <div class="home-products__stars">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            if (s <= (int)(product.AverageRating))
                                            {
                                                <i class="fa-solid fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-solid fa-star empty"></i>
                                            }
                                        }
                                    </div>
                                    <span class="home-products__review-count">(@product.ReviewCount)</span>
                                </div>
                                <div class="home-products__bottom">
                                    <span class="home-products__price">@product.Price.ToString("N0")₫</span>
                                    <span class="home-products__sold">Đã bán @product.SoldCount</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="home-empty-state">
                    <i class="fa-solid fa-seedling"></i>
                    <p>Đang cập nhật sản phẩm nổi bật...</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================================
     LATEST BLOG POSTS SECTION
     ============================================ -->
<section class="home-blog">
    <div class="container">
        <div class="home-section-header home-section-header--split reveal">
            <div>
                <h2>Bài viết nổi bật</h2>
                <p>Cập nhật những xu hướng và mẹo chăm sóc không gian sống mới nhất</p>
            </div>
            <a asp-controller="Blog" asp-action="Index" asp-route-category="Sales" class="home-section-link">
                Khám phá Blog <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>

        <div class="row g-4">
            @{
                var latestPosts = ViewBag.LatestSalesPosts as List<EcommerceApp.Application.DTOs.Blog.BlogPostDto>;
            }
            @if (latestPosts != null && latestPosts.Any())
            {
                int bIdx = 0;
                foreach (var post in latestPosts)
                {
                    bIdx++;
                    <div class="col-md-6 col-lg-3 reveal reveal-delay-@(bIdx > 4 ? 4 : bIdx)">
                        <div class="home-blog__card">
                            <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none">
                                <div class="home-blog__thumb">
                                    @if (!string.IsNullOrEmpty(post.Thumbnail))
                                    {
                                        <img src="@post.Thumbnail" alt="@post.Title">
                                    }
                                    else
                                    {
                                        <div class="home-blog__thumb-placeholder">
                                            <i class="fa-solid fa-newspaper"></i>
                                        </div>
                                    }
                                </div>
                            </a>
                            <div class="home-blog__body">
                                <div class="home-blog__date">
                                    <i class="fa-regular fa-calendar"></i>
                                    @post.CreatedAt?.ToString("dd/MM/yyyy")
                                </div>
                                <h3 class="home-blog__title">
                                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                                </h3>
                                <div class="home-blog__footer">
                                    <span class="home-blog__author">@post.AuthorName</span>
                                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id" class="home-blog__read-more">
                                        Xem thêm <i class="fa-solid fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="home-empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Đang cập nhật những bài viết mới nhất...</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================================
     NEWSLETTER SECTION
     ============================================ -->
<div class="container">
    <section class="home-newsletter reveal">
        <div class="home-newsletter__pattern"></div>
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2>Đăng ký để nhận bí quyết khơi nguồn sống xanh</h2>
                <p>Nhận ngay ưu đãi 10% cho đơn hàng đầu tiên và cẩm nang chăm sóc cây cảnh đặc quyền.</p>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="home-newsletter__form">
                    <input type="email" class="home-newsletter__input" placeholder="Nhập email của bạn...">
                    <button class="home-newsletter__btn">Đăng ký</button>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        // Scroll Reveal Animation
        document.addEventListener('DOMContentLoaded', function () {
            const revealElements = document.querySelectorAll('.reveal');

            function checkReveal() {
                const windowHeight = window.innerHeight;
                revealElements.forEach(el => {
                    const top = el.getBoundingClientRect().top;
                    if (top < windowHeight - 80) {
                        el.classList.add('revealed');
                    }
                });
            }

            // Initial check
            checkReveal();

            // Listen for scroll
            window.addEventListener('scroll', checkReveal, { passive: true });
        });
    </script>
}
