@{
    ViewData["Title"] = "Về chúng tôi";
}

<style>
    .about-hero {
        background: linear-gradient(rgba(16, 185, 129, 0.1), rgba(16, 185, 129, 0.05)), url('https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?q=80&w=2000&auto=format&fit=crop') center/cover;
        padding: 120px 0;
        text-align: center;
        border-bottom: 1px solid rgba(16, 185, 129, 0.1);
    }
    
    .section-padding { padding: 80px 0; }
    
    .stats-card {
        background: white;
        padding: 30px;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        text-align: center;
        height: 100%;
        border: 1px solid #f1f5f9;
        transition: transform 0.3s ease;
    }
    
    .stats-card:hover { transform: translateY(-5px); }
    .stats-icon { font-size: 2.5rem; color: #10b981; margin-bottom: 20px; }
    
    .map-container {
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
    
    .contact-item {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }
    
    .contact-icon {
        width: 50px;
        height: 50px;
        background: #f0fdf4;
        color: #10b981;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
</style>

<section class="about-hero mb-0">
    <div class="container">
        <h1 class="display-3 fw-bold text-dark mb-4">Green Life</h1>
        <p class="lead text-muted max-width-700 mx-auto">
            Khơi nguồn cảm hứng sống xanh, mang vẻ đẹp bình yên của thiên nhiên đến với từng không gian sống hiện đại.
        </p>
    </div>
</section>

<section class="section-padding bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1592150621344-22d506ef2383?q=80&w=1000&auto=format&fit=crop" class="img-fluid rounded-4 shadow-lg" alt="Our Story">
            </div>
            <div class="col-lg-6">
                <div class="pe-lg-5">
                    <span class="badge bg-soft-green text-primary px-3 py-2 rounded-pill mb-3">Câu chuyện của chúng tôi</span>
                    <h2 class="fw-bold display-6 mb-4">Hành trình mang nghệ thuật xanh vào cuộc sống</h2>
                    <p class="text-muted mb-4 lead">
                        Khởi đầu từ một khu vườn nhỏ với niềm đam mê dành cho những loài thực vật kỳ diệu, Green Life đã trở thành địa chỉ tin cậy của những người yêu thiên nhiên. 
                    </p>
                    <p class="text-muted mb-5">
                        Chúng tôi không chỉ bán cây, chúng tôi cung cấp giải pháp trang trí xanh toàn diện. Mỗi sản phẩm được chọn lọc kỹ lưỡng, được chăm sóc bằng tất cả tình yêu để sẵn sàng nở rộ khi về với chủ nhân mới.
                    </p>
                    <div class="row g-4">
                        <div class="col-6">
                            <h4 class="fw-bold text-primary mb-1">5+ Năm</h4>
                            <p class="small text-muted mb-0">Kinh nghiệm trong nghề</p>
                        </div>
                        <div class="col-6">
                            <h4 class="fw-bold text-primary mb-1">10,000+</h4>
                            <p class="small text-muted mb-0">Khách hàng hài lòng</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="section-padding bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold display-6 mb-3">Giá trị cốt lõi</h2>
            <p class="text-muted">Tại sao hàng ngàn khách hàng tin chọn Green Life?</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-icon"><i class="fa-solid fa-leaf"></i></div>
                    <h4 class="fw-bold">Chất lượng cao</h4>
                    <p class="text-muted mb-0">Mỗi cây đều được nuôi trồng theo quy chuẩn hữu cơ, khỏe mạnh và có khả năng thích nghi cao.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-icon"><i class="fa-solid fa-hands-holding-circle"></i></div>
                    <h4 class="fw-bold">Tư vấn tận tâm</h4>
                    <p class="text-muted mb-0">Hỗ trợ chăm sóc trọn đời, giải đáp mọi thắc mắc của bạn về quá trình nuôi trồng cây.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stats-card">
                    <div class="stats-icon"><i class="fa-solid fa-truck-fast"></i></div>
                    <h4 class="fw-bold">Giao hàng an toàn</h4>
                    <p class="text-muted mb-0">Quy trình đóng gói chuyên nghiệp và vận chuyển nhanh chóng, đảm bảo cây luôn tươi mới.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Map & Contact Section -->
<section class="section-padding bg-white">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h2 class="fw-bold display-6 mb-5">Kết nối với chúng tôi</h2>
                
                <div class="contact-item">
                    <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Địa chỉ cửa hàng</h5>
                        <p class="text-muted mb-0">456 Đường Láng, Quận Đống Đa, Hà Nội</p>
                    </div>
                </div>
                
                <div class="contact-item">
                    <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Số điện thoại liên hệ</h5>
                        <p class="text-muted mb-0">+84 (24) 3456 7890</p>
                    </div>
                </div>
                
                <div class="contact-item">
                    <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Email kinh doanh</h5>
                        <p class="text-muted mb-0">contact@greenlife.vn</p>
                    </div>
                </div>

                <div class="contact-item">
                    <div class="contact-icon"><i class="fa-solid fa-clock"></i></div>
                    <div>
                        <h5 class="fw-bold mb-1">Giờ mở cửa</h5>
                        <p class="text-muted mb-0">08:00 - 21:00 (Tất cả các ngày trong tuần)</p>
                    </div>
                </div>
                
                <div class="mt-5">
                    <h5 class="fw-bold mb-4">Theo dõi chúng tôi trên mạng xã hội</h5>
                    <div class="d-flex gap-3">
                        <a href="#" class="btn btn-outline-primary rounded-circle" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-outline-primary rounded-circle" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="btn btn-outline-primary rounded-circle" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-tiktok"></i></a>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-7">
                <div class="map-container h-100 min-height-400">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3724.4851509172675!2d105.812674314488!3d21.013264493683!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3135ab5915d66667%3A0xa1fa81d2ef077d70!2zNDU2IMSQxrDhu51uZyBMw6FuZywgTmjDom4gQ2jDrG5oLCDEkOG7kW5nIMSQYSwgSMOgIE7hu5lpLCBWaeG7h3QgTmFt!5e0!3m2!1svi!2s!4v1652367500000!5m2!1svi!2s" 
                            width="100%" height="450" style="border:0; min-height: 450px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .bg-soft-green { background-color: #f0fdf4 !important; }
    .max-width-700 { max-width: 700px; }
    .min-height-400 { min-height: 400px; }
</style>
