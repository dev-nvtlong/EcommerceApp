@model IEnumerable<EcommerceApp.Application.DTOs.Product.ProductDto>
@{
    ViewData["Title"] = "Cửa hàng";
    var categories = ViewBag.Categories as List<EcommerceApp.Application.DTOs.Category.CategoryDto>;
}

<style>
    :root {
        --emerald-primary: #10b981;
        --emerald-dark: #064e3b;
        --emerald-light: #ecfdf5;
    }

    .product-card {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        background: #fff;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08) !important;
        }

    .product-card__image {
        aspect-ratio: 4 / 5;
        background: #f8fafc;
    }

    .product-card__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .product-card:hover .product-card__img {
        transform: scale(1.1);
    }

    .product-card__placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
    }

    .product-card__overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
    }

    .product-card__actions {
        position: absolute;
        bottom: -50px;
        left: 0;
        right: 0;
        padding: 1rem;
        display: flex;
        justify-content: center;
        transition: all 0.3s ease;
        z-index: 3;
    }

    .product-card:hover .product-card__actions {
        bottom: 0;
    }

    .btn-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: none;
    }

    .product-card__title {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.8em;
        line-height: 1.4;
    }

        .product-card__title a:hover {
            color: var(--emerald-primary) !important;
        }

    .btn-emerald-outline {
        border: 2px solid var(--emerald-light);
        color: var(--emerald-dark);
        background: var(--emerald-light);
        transition: all 0.3s ease;
    }

        .btn-emerald-outline:hover {
            background: var(--emerald-primary);
            border-color: var(--emerald-primary);
            color: white;
        }

    .btn-emerald-primary {
        background-color: var(--emerald-primary);
        border-color: var(--emerald-primary);
        color: white;
        transition: all 0.3s ease;
    }

        .btn-emerald-primary:hover {
            background-color: var(--emerald-dark);
            border-color: var(--emerald-dark);
            color: white;
            transform: scale(1.02);
        }

    .btn-emerald-soft {
        background-color: var(--emerald-light);
        color: var(--emerald-dark);
        transition: all 0.3s ease;
    }

        .btn-emerald-soft:hover {
            background-color: #d1fae5;
            color: var(--emerald-primary);
        }

    .btn-white {
        background: white;
        color: var(--emerald-dark);
    }

    .product-card__qty button:hover {
        background: rgba(255, 255, 255, 0.8) !important;
        color: var(--emerald-primary) !important;
    }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* SHOP BANNER */
    .shop-banner {
        background: linear-gradient(135deg, #064e3b 0%, #065f46 100%);
        border-radius: 30px;
        position: relative;
        overflow: hidden;
        margin-top: 0;
        padding: 2.5rem 4rem;
        color: white;
    }
    .shop-banner__img {
        position: absolute;
        right: 0;
        top: 0;
        height: 100%;
        opacity: 0.3;
        z-index: 1;
    }
    .shop-banner__content {
        position: relative;
        z-index: 2;
        max-width: 600px;
    }

    .bg-emerald-400 {
        background-color: #34d399 !important;
    }

    .text-emerald-300 {
        color: #6ee7b7 !important;
    }

    .btn-emerald-400 {
        background-color: #34d399;
        border-color: #34d399;
        color: #064e3b;
    }

        .btn-emerald-400:hover {
            background-color: #10b981;
            border-color: #10b981;
            color: white;
        }
</style>

<div class="container mt-3 mb-4">
    <div class="shop-banner shadow-sm">
        <img src="https://images.unsplash.com/photo-1545241047-6083a3684587?q=80&w=1200&auto=format&fit=crop" class="shop-banner__img" alt="Plant Decoration">
        <div class="shop-banner__content animate__animated animate__fadeInLeft">
            <span class="badge bg-emerald-400 bg-opacity-25 text-emerald-300 px-3 py-2 rounded-pill mb-3 fw-bold">
                <i class="fa-solid fa-leaf me-2"></i> BỘ SƯU TẬP MÙA XUÂN
            </span>
            <h1 class="display-6 fw-bold mb-2">TẬN HƯỞNG KHÔNG GIAN SỐNG <span class="text-emerald-300">TRONG LÀNH</span></h1>
            <p class="mb-4 opacity-75 small">Lựa chọn những loài cây phong thủy tốt nhất cho phòng làm việc và ngôi nhà của bạn.</p>
            <div class="d-flex gap-3">
                <a href="#filterForm" class="btn btn-emerald-400 rounded-pill px-4 fw-bold btn-sm">Khám phá ngay</a>
                <a href="#" class="btn btn-outline-light rounded-pill px-4 fw-bold btn-sm">Xem ưu đãi</a>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <!-- Sidebar Filters -->
        <aside class="col-lg-3">
            <form method="get" action="@Url.Action("Index")" id="filterForm">
                <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategory" />
                <input type="hidden" name="sortOrder" id="sortOrderInput" value="@ViewBag.SortOrder" />

                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                    <h2 class="h5 fw-bold mb-4">Danh mục sản phẩm</h2>
                    @{
                        var allCats = categories ?? new List<EcommerceApp.Application.DTOs.Category.CategoryDto>();
                        var plantKeywords = new[] { "Cây", "Hoa", "Sen", "Kiểng", "Lan", "Trầu", "Xương", "Rồng", "Lá" };
                        var medKeywords = new[] { "Thuốc", "Phân", "Trị", "Dưỡng", "Kích", "Trừ", "Dung dịch", "Xịt" };

                        var plantCats = allCats.Where(c => plantKeywords.Any(k => c.Name.Contains(k, StringComparison.OrdinalIgnoreCase))).ToList();
                        var medCats = allCats.Where(c => medKeywords.Any(k => c.Name.Contains(k, StringComparison.OrdinalIgnoreCase))).ToList();
                        var otherCats = allCats.Except(plantCats).Except(medCats).ToList();
                        plantCats.AddRange(otherCats);
                    }

                    <div class="mb-4">
                        <label class="small fw-bold text-muted mb-2 d-block">CHỌN CÂY TRỒNG</label>
                        <select class="form-select border-0 bg-light rounded-3 shadow-none py-2" 
                                onchange="if(this.value) window.location.href=this.value">
                            <option value="@Url.Action("Index", new { categoryId = "", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, sortOrder = ViewBag.SortOrder })">-- Tất cả loại cây --</option>
                            @foreach (var cat in plantCats)
                            {
                                <!option value="@Url.Action("Index", new { categoryId = cat.Id, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, sortOrder = ViewBag.SortOrder })" 
                                         @(ViewBag.CurrentCategory == (int?)cat.Id ? "selected" : "")>@cat.Name</!option>
                            }
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="small fw-bold text-muted mb-2 d-block">VẬT TƯ & THUỐC</label>
                        <select class="form-select border-0 bg-light rounded-3 shadow-none py-2" 
                                onchange="if(this.value) window.location.href=this.value">
                            <option value="@Url.Action("Index", new { categoryId = "", minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, sortOrder = ViewBag.SortOrder })">-- Chọn vật tư --</option>
                            @foreach (var cat in medCats)
                            {
                                <!option value="@Url.Action("Index", new { categoryId = cat.Id, minPrice = ViewBag.MinPrice, maxPrice = ViewBag.MaxPrice, sortOrder = ViewBag.SortOrder })" 
                                         @(ViewBag.CurrentCategory == (int?)cat.Id ? "selected" : "")>@cat.Name</!option>
                            }
                        </select>
                    </div>
                    
                    <hr class="my-4 text-muted opacity-25">
                    
                    <h2 class="h5 fw-bold mb-4">Khoảng giá</h2>
                    <div class="mb-3">
                        <div class="d-flex gap-2 align-items-center mb-2">
                            <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control form-control-sm border-0 bg-light rounded-3" placeholder="Từ">
                            <span class="text-muted">-</span>
                            <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control form-control-sm border-0 bg-light rounded-3" placeholder="Đến">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill btn-sm fw-bold py-2 shadow-sm">
                        Áp dụng lọc giá
                    </button>
                    @if (ViewBag.MinPrice != null || ViewBag.MaxPrice != null || ViewBag.CurrentCategory != null)
                    {
                        <a asp-action="Index" class="btn btn-link btn-sm text-danger w-100 mt-2 text-decoration-none">Xóa tất cả bộ lọc</a>
                    }
                </div>
            </form>
        </aside>

        <!-- Product Grid -->
        <main class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
                <p class="text-muted mb-0 small"><i class="fa-solid fa-layer-group me-2"></i>Tìm thấy <strong>@Model.Count()</strong> sản phẩm</p>
                <div class="d-flex align-items-center gap-3">
                    <span class="small text-muted d-none d-sm-inline">Sắp xếp:</span>
                    <select class="form-select form-select-sm w-auto border-0 bg-light rounded-pill px-3 shadow-none fw-semibold" onchange="applySort(this.value)" style="padding-right: 2rem !important">
                        <!option value="newest" @(ViewBag.SortOrder == "newest" ? "selected" : "")>Mới nhất</!option>
                        <!option value="price_asc" @(ViewBag.SortOrder == "price_asc" ? "selected" : "")>Giá: Thấp đến Cao</!option>
                        <!option value="price_desc" @(ViewBag.SortOrder == "price_desc" ? "selected" : "")>Giá: Cao đến Thấp</!option>
                    </select>
                </div>
            </div>

            <div class="row g-3 g-md-4">
                @foreach (var p in Model)
                {
                    <div class="col-6 col-md-4 col-xl-3">
                        <div class="card product-card border-0 shadow-sm rounded-4 h-100 overflow-hidden group">
                            <!-- Image Section -->
                            <div class="product-card__image position-relative overflow-hidden">
                                <a asp-action="Details" asp-route-id="@p.ProductId" class="d-block">
                                    @if (p.ImageUrls != null && p.ImageUrls.Any())
                                    {
                                        <img src="@p.ImageUrls[0]" class="product-card__img" alt="@p.Name">
                                    }
                                    else
                                    {
                                        <div class="product-card__placeholder">
                                            <i class="fa-solid fa-image text-muted opacity-25"></i>
                                        </div>
                                    }
                                </a>
                                @if (p.Price <= 0)
                                {
                                    <div class="product-card__overlay">
                                        <span class="badge bg-danger rounded-pill px-3 py-2 fw-bold shadow-sm">HẾT HÀNG</span>
                                    </div>
                                }
                            </div>

                            <!-- Content Section -->
                            <div class="card-body p-3 d-flex flex-column">
                                <h3 class="product-card__title h6 fw-bold mb-1">
                                    <a asp-action="Details" asp-route-id="@p.ProductId" class="text-dark text-decoration-none">@p.Name</a>
                                </h3>
                                
                                <div class="mb-2">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <div class="rating-stars small text-warning">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fa-@(i <= Math.Round(p.AverageRating) ? "solid" : "regular") fa-star"></i>
                                            }
                                        </div>
                                        <span class="text-muted" style="font-size: 0.7rem;">(@p.ReviewCount)</span>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-light text-secondary border-0 rounded-pill small fw-normal" style="font-size: 0.65rem; padding: 0.25rem 0.6rem;">
                                            <i class="fa-solid fa-box-open me-1 opacity-75"></i>Kho: @p.StockQuantity
                                            <span class="mx-1 opacity-25">|</span> 
                                            <i class="fa-solid fa-fire-flame-curved me-1 text-danger opacity-75"></i>Đã bán @p.SoldCount
                                        </span>
                                    </div>
                                </div>

                                <div class="product-card__price mb-3 mt-auto pt-2">
                                    <span class="fs-5 fw-bold text-success">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</span>
                                </div>
                                
                                <div class="product-card__actions-wrapper mt-auto pt-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <!-- Chọn số lượng -->
                                        <div class="product-card__qty border-0 rounded-pill d-flex align-items-center bg-light px-1 flex-grow-1" style="height: 36px;">
                                            <button type="button" class="btn btn-sm btn-link p-0 text-emerald-dark shadow-none border-0 text-decoration-none" 
                                                    style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; border-radius: 50%;"
                                                    onclick="const input = document.getElementById('qty-@p.ProductId'); input.value = Math.max(1, parseInt(input.value) - 1)">
                                                <i class="fa-solid fa-minus" style="font-size: 0.65rem;"></i>
                                            </button>
                                            <input type="number" id="qty-@p.ProductId" value="1" min="1" 
                                                   class="form-control form-control-sm border-0 bg-transparent text-center fw-bold p-0 shadow-none" 
                                                   style="width: 100%; font-size: 0.9rem; color: var(--emerald-dark);">
                                            <button type="button" class="btn btn-sm btn-link p-0 text-emerald-dark shadow-none border-0 text-decoration-none" 
                                                    style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; border-radius: 50%;"
                                                    onclick="const input = document.getElementById('qty-@p.ProductId'); input.value = parseInt(input.value) + 1">
                                                <i class="fa-solid fa-plus" style="font-size: 0.65rem;"></i>
                                            </button>
                                        </div>
                                        
                                        <!-- Thêm vào giỏ hàng -->
                                        <button onclick="addToCart(@p.ProductId, parseInt(document.getElementById('qty-@p.ProductId').value))" 
                                                class="btn btn-emerald-soft shadow-none d-flex align-items-center justify-content-center border-0" 
                                                style="height: 36px; width: 45px; border-radius: 50px;" title="Thêm vào giỏ">
                                            <i class="fa-solid fa-cart-plus"></i>
                                        </button>
                                    </div>
                                    
                                    <!-- Mua ngay -->
                                    <button onclick="buyNow(@p.ProductId, parseInt(document.getElementById('qty-@p.ProductId').value))" 
                                            class="btn btn-emerald-primary text-white w-100 rounded-pill btn-sm fw-bold py-2 shadow-sm">
                                        MUA NGAY
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="fa-solid fa-wind display-1 text-muted opacity-10"></i>
                    </div>
                    <h5 class="text-muted">Không tìm thấy sản phẩm nào</h5>
                    <p class="small text-muted">Vui lòng thử lại với bộ lọc khác hoặc từ khóa khác.</p>
                </div>
            }
        </main>
    </div>
</div>

@section Scripts {
    <script>
        function applySort(val) {
            document.getElementById('sortOrderInput').value = val;
            document.getElementById('filterForm').submit();
        }
    </script>
}
