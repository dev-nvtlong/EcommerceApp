@model IEnumerable<EcommerceApp.Application.DTOs.Product.ProductDto>
@{
    ViewData["Title"] = "Cửa hàng";
    var categories = ViewBag.Categories as List<EcommerceApp.Application.DTOs.Category.CategoryDto>;
}

<div class="py-5 bg-white border-bottom">
    <div class="container">
        <h1 class="fw-bold mb-0">Cửa hàng</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 mt-2">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Cửa hàng</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Filters -->
        <aside class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h3 class="h5 fw-bold mb-4">Danh mục</h3>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" asp-route-categoryId="" 
                       class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center @(ViewBag.CurrentCategory == null ? "text-primary fw-bold" : "text-muted")">
                        Tất cả sản phẩm
                    </a>
                    @foreach (var cat in categories)
                    {
                        <a asp-action="Index" asp-route-categoryId="@cat.Id" 
                           class="list-group-item list-group-item-action border-0 px-0 d-flex justify-content-between align-items-center @(ViewBag.CurrentCategory == (int?)cat.Id ? "text-primary fw-bold" : "text-muted")">
                            @cat.Name
                        </a>
                    }
                </div>
                
                <hr class="my-4 text-muted opacity-25">
                
                <h3 class="h5 fw-bold mb-4">Lọc theo giá</h3>
                <input type="range" class="form-range mb-3" min="0" max="10000000" step="100000">
                <div class="d-flex justify-content-between text-muted small">
                    <span>0đ</span>
                    <span>10.000.000đ</span>
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <main class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <p class="text-muted mb-0">Hiển thị @Model.Count() sản phẩm</p>
                <select class="form-select w-auto border-0 shadow-sm rounded-pill px-4">
                    <option>Sắp xếp theo: Mới nhất</option>
                    <option>Giá: Thấp đến Cao</option>
                    <option>Giá: Cao đến Thấp</option>
                </select>
            </div>

            <div class="row g-4">
                @foreach (var p in Model)
                {
                    <div class="col-6 col-md-4">
                        <div class="card border-0 bg-white shadow-sm rounded-4 h-100 group overflow-hidden">
                            <div class="position-relative overflow-hidden" style="aspect-ratio: 1/1;">
                                @if (p.ImageUrls != null && p.ImageUrls.Any())
                                {
                                    <img src="@p.ImageUrls[0]" class="w-100 h-100 object-fit-cover transition-transform duration-500" alt="@p.Name">
                                }
                                else
                                {
                                    <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                        <i class="fa-solid fa-image text-muted opacity-50 h1"></i>
                                    </div>
                                }
                                <div class="position-absolute bottom-0 start-0 w-100 p-3 translate-y-100 group-hover-translate-y-0 transition-all opacity-0 group-hover-opacity-100">
                                    <button onclick="addToCart(@p.ProductId)" class="btn btn-primary w-100 rounded-pill fw-bold shadow">
                                        Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                            <div class="card-body p-3">
                                <h3 class="h6 fw-semibold mb-1 text-truncate">@p.Name</h3>
                                <div class="text-primary fw-bold">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-box-open h1 text-muted opacity-25 mb-3"></i>
                    <p class="text-muted">Không tìm thấy sản phẩm nào trong danh mục này.</p>
                </div>
            }
        </main>
    </div>
</div>

<style>
    .group:hover img { transform: scale(1.1); }
    .duration-500 { transition-duration: 500ms; }
</style>
