@model EcommerceApp.Application.DTOs.Account.UserDto
@using EcommerceApp.Enums
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="py-5 bg-white border-bottom">
    <div class="container">
        <h1 class="fw-bold mb-0">Tài khoản của tôi</h1>
        <p class="text-muted mt-2">Quản lý thông tin hồ sơ của bạn để bảo mật tài khoản</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                <div class="text-center mb-4">
                    <div class="position-relative d-inline-block">
                        <img src="@(string.IsNullOrEmpty(Model.Avatar) ? "https://ui-avatars.com/api/?name=" + Model.FullName + "&background=74b49b&color=fff&size=128" : Model.Avatar)" 
                             id="avatarPreview"
                             class="rounded-circle border border-4 border-white shadow-sm" 
                             style="width: 120px; height: 120px; object-fit: cover;">
                        <label for="avatarInput" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 shadow-sm cursor-pointer" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fa-solid fa-camera"></i>
                        </label>
                    </div>
                    <h5 class="fw-bold mt-3 mb-1">@Model.FullName</h5>
                    <p class="text-muted small mb-0">@Model.Email</p>
                </div>
                
                <div class="nav flex-column nav-pills">
                    <a class="nav-link active rounded-3 mb-2" href="@Url.Action("Profile", "Account")">
                        <i class="fa-solid fa-user me-2"></i> Hồ sơ cá nhân
                    </a>
                    <a class="nav-link text-dark rounded-3 mb-2" href="@Url.Action("Index", "Order")">
                        <i class="fa-solid fa-box me-2"></i> Đơn hàng của tôi
                    </a>
                    <form asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-link text-danger w-100 text-start rounded-3">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Setting Content -->
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <h4 class="fw-bold mb-4">Thông tin hồ sơ</h4>
                
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 rounded-4 mb-4 py-3 px-4 shadow-sm d-flex align-items-center">
                        <i class="fa-solid fa-circle-check me-3 h4 mb-0"></i>
                        <div>@TempData["Success"]</div>
                    </div>
                }

                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    <input type="file" name="avatarFile" id="avatarInput" class="d-none" accept="image/*" onchange="previewImage(this)">
                    
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Họ và tên</label>
                            <input type="text" name="FullName" value="@Model.FullName" class="form-control border-0 bg-light rounded-3 px-3 py-2 shadow-none" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Email (Không thể thay đổi)</label>
                            <input type="email" value="@Model.Email" class="form-control border-0 bg-light rounded-3 px-3 py-2 shadow-none opacity-75" disabled>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Số điện thoại</label>
                            <input type="tel" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control border-0 bg-light rounded-3 px-3 py-2 shadow-none">
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold text-uppercase">Ngày sinh</label>
                            <input type="date" name="DateOfBirth" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" class="form-control border-0 bg-light rounded-3 px-3 py-2 shadow-none">
                        </div>
                        
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold text-uppercase">Giới tính</label>
                            <div class="d-flex gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Gender" id="genderMale" value="@((int)GenderType.Male)" @(Model.Gender == GenderType.Male ? "checked" : "")>
                                    <label class="form-check-label" for="genderMale">Nam</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Gender" id="genderFemale" value="@((int)GenderType.Female)" @(Model.Gender == GenderType.Female ? "checked" : "")>
                                    <label class="form-check-label" for="genderFemale">Nữ</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="Gender" id="genderOther" value="@((int)GenderType.Other)" @(Model.Gender == GenderType.Other ? "checked" : "")>
                                    <label class="form-check-label" for="genderOther">Khác</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold text-uppercase">Địa chỉ</label>
                            <textarea name="Address" rows="3" class="form-control border-0 bg-light rounded-3 px-3 py-2 shadow-none">@Model.Address</textarea>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg">
                                <i class="fa-solid fa-save me-2"></i> Lưu thay đổi
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#avatarPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

<style>
    .cursor-pointer { cursor: pointer; }
    .nav-link.active { background-color: #74b49b !important; color: white !important; }
    .nav-link:not(.active):hover { background-color: #f8f9fa; }
    .nav-link { padding: 12px 16px; transition: all 0.3s; }
    form-control:focus, .form-select:focus { background-color: #f1f3f5; }
</style>
