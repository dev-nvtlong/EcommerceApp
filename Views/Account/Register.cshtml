@model EcommerceApp.Application.Features.Auth.Register.RegisterRequest
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "_AuthLayout";
}

<div class="login-page">
    <!-- Left Panel - Branding -->
    <div class="login-brand-panel">
        <div class="brand-overlay"></div>
        <div class="brand-content">
            <div class="brand-icon animate__animated animate__fadeInDown">
                <i class="fa-solid fa-seedling"></i>
            </div>
            <h1 class="brand-title animate__animated animate__fadeInUp">Green Life</h1>
            <p class="brand-subtitle animate__animated animate__fadeInUp animate__delay-1s">
                Chăm sóc không gian xanh — Nơi mỗi chiếc cây là một câu chuyện.
            </p>
            <div class="brand-features animate__animated animate__fadeInUp animate__delay-1s">
                <div class="feature-item">
                    <i class="fa-solid fa-leaf"></i>
                    <span>Hàng ngàn loại cây trồng</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-truck-fast"></i>
                    <span>Giao hàng tận nơi</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-star"></i>
                    <span>Tư vấn chuyên gia miễn phí</span>
                </div>
            </div>
            <div class="brand-cta">
                <p class="text-white-50 mb-3 small">Đã có tài khoản?</p>
                <a asp-action="Login" class="btn-register-link">
                    Đăng nhập ngay <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Right Panel - Form -->
    <div class="login-form-panel">
        <div class="login-form-wrapper animate__animated animate__fadeInRight">

            <div class="form-header">
                <h2 class="form-title">Đăng ký tài khoản!</h2>
                <p class="form-subtitle text-muted">Bắt đầu hành trình xanh của bạn cùng Green Life</p>
            </div>

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-error animate__animated animate__shakeX">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Register" method="post" id="register-form">
                @Html.AntiForgeryToken()

                <div class="input-group-custom">
                    <label asp-for="FullName" class="input-label">Họ và tên</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-user input-icon"></i>
                        <input asp-for="FullName"
                               class="form-input"
                               placeholder="Nguyễn Văn A"
                               autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="field-error"></span>
                </div>

                <div class="input-group-custom">
                    <label asp-for="Email" class="input-label">Email</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-envelope input-icon"></i>
                        <input asp-for="Email"
                               type="email"
                               class="form-input"
                               placeholder="example@gmail.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="input-group-custom">
                    <label asp-for="Password" class="input-label">Mật khẩu</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock input-icon"></i>
                        <input asp-for="Password"
                               type="password"
                               class="form-input"
                               placeholder="••••••••"
                               autocomplete="new-password"
                               id="password-input" />
                        <button type="button" class="toggle-password" id="toggle-pwd" tabindex="-1">
                            <i class="fa-regular fa-eye" id="eye-icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <button type="submit" class="btn-login" id="btn-register">
                    <span class="btn-text">
                        <i class="fa-solid fa-user-plus me-2"></i>Đăng ký
                    </span>
                    <span class="btn-spinner d-none">
                        <i class="fa-solid fa-spinner fa-spin me-2"></i>Đang xử lý...
                    </span>
                </button>
            </form>

            <p class="register-prompt">
                Đã có tài khoản?
                <a asp-action="Login" class="register-link">Đăng nhập</a>
            </p>
        </div>
    </div>
</div>

<style>
    /* ===== RESET & BASE ===== */
    * { box-sizing: border-box; }

    body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        background: #f0f4f0;
    }

    .auth-logo { display: none !important; }

    /* ===== LAYOUT ===== */
    .login-page {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
    }

    /* ===== LEFT BRAND PANEL ===== */
    .login-brand-panel {
        position: relative;
        background-image: url('https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1200&q=80');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .brand-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(21, 128, 61, 0.88) 0%, rgba(5, 46, 22, 0.95) 100%);
    }

    .brand-content {
        position: relative;
        z-index: 2;
        color: white;
        text-align: center;
        padding: 2.5rem;
        max-width: 420px;
    }

    .brand-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
        color: #a7f3d0;
    }

    .brand-title {
        font-size: 2.6rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        margin-bottom: 0.75rem;
        color: white;
    }

    .brand-subtitle {
        font-size: 1rem;
        color: rgba(255,255,255,0.75);
        line-height: 1.7;
        margin-bottom: 2.5rem;
    }

    .brand-features {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        margin-bottom: 2.5rem;
        text-align: left;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 0.65rem 1rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.9);
        backdrop-filter: blur(4px);
        transition: background 0.3s;
    }

    .feature-item:hover {
        background: rgba(255,255,255,0.15);
    }

    .feature-item i {
        color: #6ee7b7;
        font-size: 1rem;
        width: 20px;
        text-align: center;
    }

    .brand-cta { margin-top: 0.5rem; }

    .btn-register-link {
        display: inline-flex;
        align-items: center;
        background: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.5);
        color: white;
        text-decoration: none;
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
    }

    .btn-register-link:hover {
        background: white;
        color: #16a34a;
        border-color: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    /* ===== RIGHT FORM PANEL ===== */
    .login-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fafffe;
        padding: 2rem;
    }

    .login-form-wrapper {
        width: 100%;
        max-width: 420px;
    }

    /* ===== FORM HEADER ===== */
    .form-header { margin-bottom: 1.8rem; }

    .form-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 0.4rem;
        letter-spacing: -0.5px;
    }

    .form-subtitle {
        font-size: 0.95rem;
        color: #6b7280;
    }

    /* ===== ALERTS ===== */
    .alert-error {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-left: 4px solid #ef4444;
        border-radius: 10px;
        padding: 0.85rem 1rem;
        margin-bottom: 1.25rem;
        color: #b91c1c;
        font-size: 0.88rem;
    }

    .alert-error ul { margin: 0; padding-left: 1rem; }

    /* ===== INPUT GROUPS ===== */
    .input-group-custom {
        margin-bottom: 1.1rem;
    }

    .input-label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.4rem;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        color: #9ca3af;
        font-size: 0.9rem;
        pointer-events: none;
        transition: color 0.2s;
    }

    .form-input {
        width: 100%;
        padding: 0.8rem 1rem 0.8rem 2.7rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        font-size: 0.95rem;
        color: #111827;
        background: white;
        outline: none;
        transition: all 0.25s ease;
        font-family: inherit;
    }

    .form-input:focus {
        border-color: #16a34a;
        box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.08);
    }

    .form-input:focus + .input-icon,
    .input-wrapper:focus-within .input-icon {
        color: #16a34a;
    }

    .form-input::placeholder { color: #d1d5db; }

    .toggle-password {
        position: absolute;
        right: 0.9rem;
        background: none;
        border: none;
        cursor: pointer;
        color: #9ca3af;
        padding: 0;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        transition: color 0.2s;
    }

    .toggle-password:hover { color: #16a34a; }
    .toggle-password:focus { outline: none; }

    .field-error {
        display: block;
        font-size: 0.78rem;
        color: #ef4444;
        margin-top: 0.3rem;
        min-height: 1rem;
    }

    /* ===== REGISTER BUTTON ===== */
    .btn-login {
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.3px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
        position: relative;
        overflow: hidden;
        margin-top: 1rem;
    }

    .btn-login::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 100%);
        opacity: 0;
        transition: opacity 0.3s;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(22, 163, 74, 0.4);
    }

    .btn-login:hover::before { opacity: 1; }

    .btn-login:active {
        transform: translateY(0);
        box-shadow: 0 4px 15px rgba(22, 163, 74, 0.3);
    }

    .btn-login:focus { outline: none; }

    /* ===== REGISTER PROMPT ===== */
    .register-prompt {
        text-align: center;
        font-size: 0.88rem;
        color: #6b7280;
        margin-top: 1.5rem;
        margin-bottom: 0;
    }

    .register-link {
        color: #16a34a;
        font-weight: 600;
        text-decoration: none;
    }

    .register-link:hover {
        color: #15803d;
        text-decoration: underline;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .login-page {
            grid-template-columns: 1fr;
        }

        .login-brand-panel {
            min-height: 220px;
            padding: 2rem;
        }

        .brand-features { display: none; }

        .brand-title { font-size: 1.8rem; }

        .login-form-panel {
            padding: 2rem 1.5rem;
        }
    }
</style>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        // Toggle password visibility
        const toggleBtn = document.getElementById('toggle-pwd');
        const pwdInput  = document.getElementById('password-input');
        const eyeIcon   = document.getElementById('eye-icon');

        if(toggleBtn) {
            toggleBtn.addEventListener('click', function () {
                if (pwdInput.type === 'password') {
                    pwdInput.type = 'text';
                    eyeIcon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    pwdInput.type = 'password';
                    eyeIcon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        }

        // Loading state on submit
        const form    = document.getElementById('register-form');
        const btnText = document.querySelector('.btn-text');
        const btnSpin = document.querySelector('.btn-spinner');

        if(form) {
            form.addEventListener('submit', function () {
                btnText.classList.add('d-none');
                btnSpin.classList.remove('d-none');
            });
        }

        // Focus animation
        document.querySelectorAll('.form-input').forEach(function (input) {
            input.addEventListener('focus', function () {
                this.closest('.input-wrapper').querySelector('.input-icon').style.color = '#16a34a';
            });
            input.addEventListener('blur', function () {
                if (!this.value) {
                    this.closest('.input-wrapper').querySelector('.input-icon').style.color = '';
                }
            });
        });
    </script>
}
