@model EcommerceApp.Application.DTOs.Cart.CartDto
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="py-5 bg-white border-bottom">
    <div class="container">
        <h1 class="fw-bold mb-0">Giỏ hàng của bạn</h1>
        <p class="text-muted mt-2">Bạn đang có <span class="fw-bold pulse-text">@Model.TotalItems</span> sản phẩm trong giỏ.</p>
    </div>
</div>

<div class="container py-5">
    @if (Model.Items.Any())
    {
        <div class="row g-5">
            <!-- Items List -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3">Sản phẩm</th>
                                    <th class="py-3 text-center">Giá</th>
                                    <th class="py-3 text-center">Số lượng</th>
                                    <th class="py-3 text-end">Thành tiền</th>
                                    <th class="py-3 pe-4 text-end"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="border-bottom">
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="rounded-3 shadow-sm border overflow-hidden" style="width: 80px; aspect-ratio: 1/1;">
                                                    @if (item.Product?.ImageUrls != null && item.Product.ImageUrls.Any())
                                                    {
                                                        <img src="@item.Product.ImageUrls[0]" class="w-100 h-100 object-fit-cover" alt="@item.Product.Name">
                                                    }
                                                    else
                                                    {
                                                        <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                                                            <i class="fa-solid fa-image text-muted opacity-25"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div>
                                                    <h4 class="h6 fw-bold mb-1 text-dark">@item.Product?.Name</h4>
                                                    <span class="small text-muted">Mã SP: #@item.ProductId</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 fw-medium text-center text-muted">
                                            @item.Product?.Price.ToString("N0")₫
                                        </td>
                                        <td class="py-4">
                                            <div class="d-flex justify-content-center">
                                                <div class="input-group input-group-sm rounded-pill overflow-hidden border shadow-sm" style="width: 110px; height: 35px;">
                                                    <button class="btn btn-white border-0" onclick="updateQuantity(@item.ProductId, @(item.Quantity - 1))"><i class="fa-solid fa-minus fs-xs"></i></button>
                                                    <input type="text" class="form-control text-center border-0 bg-white fw-bold px-0" value="@item.Quantity" readonly>
                                                    <button class="btn btn-white border-0" onclick="updateQuantity(@item.ProductId, @(item.Quantity + 1))"><i class="fa-solid fa-plus fs-xs"></i></button>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 text-end fw-bold text-success">
                                            @item.SubTotal.ToString("N0")₫
                                        </td>
                                        <td class="py-4 text-end pe-4">
                                            <button onclick="removeItem(@item.ProductId)" class="btn btn-light btn-sm rounded-circle shadow-sm text-danger border-0 d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Xóa khỏi giỏ">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <div class="mt-4">
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-bold">
                        <i class="fa-solid fa-arrow-left me-2"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-lg rounded-4 p-4 sticky-top" style="top: 100px; z-index: 10;">
                    <h3 class="h5 fw-bold mb-4">Tổng số tiền</h3>
                    
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Tạm tính</span>
                        <span>@Model.TotalAmount.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Phí vận chuyển</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5 fw-bold">Tổng cộng</span>
                        <span class="h5 fw-bold text-primary">@Model.TotalAmount.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</span>
                    </div>
                    
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-lg mb-3">
                        TIẾN HÀNH THANH TOÁN
                    </a>
                    
                    <div class="text-center">
                        <img src="https://img.icons8.com/color/48/000000/visa.png" width="30">
                        <img src="https://img.icons8.com/color/48/000000/mastercard.png" width="30">
                        <img src="https://img.icons8.com/color/48/000000/paypal.png" width="30">
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="display-1 text-muted opacity-25 mb-4">
                <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <h2 class="fw-bold">Giỏ hàng của bạn đang trống</h2>
            <p class="text-muted">Hãy chọn cho mình những chậu cây ưng ý nhất nhé!</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-3 mt-3 fw-bold shadow">
                ĐẾN CỬA HÀNG NGAY
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function updateQuantity(productId, quantity) {
            if (quantity < 1) {
                removeItem(productId);
                return;
            }
            $.post('/Cart/UpdateQuantity', { productId: productId, quantity: quantity }, function(res) {
                if (res.success) location.reload();
            });
        }

        function removeItem(productId) {
            if (confirm('Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                $.post('/Cart/RemoveItem', { productId: productId }, function(res) {
                    if (res.success) location.reload();
                });
            }
        }
    </script>
}
