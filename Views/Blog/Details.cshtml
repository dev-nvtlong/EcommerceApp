@using EcommerceApp.Enums
@model EcommerceApp.Application.DTOs.Blog.BlogPostDto
@{
    ViewData["Title"] = Model.Title;
}

<style>
    :root {
        --bs-success-rgb: 45, 106, 79;
        --success-soft: rgba(45, 106, 79, 0.1);
    }

    .bg-light-gray {
        background-color: #f4f7f6;
    }

    .blog-card {
        border: none;
        transition: transform 0.3s ease;
    }

    .post-featured-image {
        position: relative;
        overflow: hidden;
    }

    .post-category-badge {
        position: absolute;
        bottom: 20px;
        left: 20px;
        z-index: 10;
    }

    .blog-content {
        color: #333;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

        .blog-content img {
            max-width: 100%;
            height: auto !important;
            border-radius: 1.5rem;
            margin: 2.5rem 0;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .blog-content h2 {
            font-weight: 800;
            color: #1b4332;
            margin-top: 3.5rem;
            margin-bottom: 1.5rem;
            letter-spacing: -0.02em;
        }

        .blog-content p {
            margin-bottom: 1.8rem;
        }

    .comment-item {
        border: 1px solid transparent !important;
    }

        .comment-item:hover {
            border-color: #d8e2dc !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }

    .hover-text-success:hover {
        color: #2d6a4f !important;
    }

    .focus-ring-success:focus {
        border-color: #2d6a4f !important;
        box-shadow: 0 0 0 0.25rem rgba(45, 106, 79, 0.15) !important;
    }

    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }

    .alert-soft-warning {
        background-color: #fffcf0;
        border-left: 4px solid #ffc107 !important;
    }

    /* Custom styles for blockquotes in blog content */
    .blog-content blockquote {
        border-left: 5px solid #2d6a4f;
        padding: 1.5rem 2rem;
        background: #f8fbf9;
        font-style: italic;
        margin: 2.5rem 0;
        border-radius: 0 1rem 1rem 0;
    }
</style>

<div class="bg-light-gray py-5 min-vh-100">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted transition-all hover-text-success">Trang chủ</a></li>
                        <li class="breadcrumb-item">
                            <a asp-action="Index" asp-route-category="@Model.Category" class="text-decoration-none text-muted transition-all hover-text-success">
                                @(Model.Category == BlogCategory.Sales ? "Bài viết" : "Kinh nghiệm")
                            </a>
                        </li>
                        <li class="breadcrumb-item active text-truncate font-weight-medium" style="max-width: 300px;">@Model.Title</li>
                    </ol>
                </nav>

                <!-- Post Content Card -->
                <article class="blog-card blog-post bg-white rounded-4 shadow-sm overflow-hidden mb-5">
                    <div class="p-4 p-md-5">
                        <header class="mb-4">
                            <div class="mb-3">
                                <span class="badge @(Model.Category == BlogCategory.Sales ? "bg-primary" : "bg-success") rounded-pill px-3 py-2 fw-bold shadow-sm">
                                    <i class="fa-solid @(Model.Category == BlogCategory.Sales ? "fa-tags" : "fa-layer-group") me-1"></i>
                                    @(Model.Category == BlogCategory.Sales ? "Bài viết sản phẩm" : "Kinh nghiệm & Bí quyết")
                                </span>
                            </div>

                            <h1 class="display-5 fw-bold text-dark mb-4 lh-sm">@Model.Title</h1>
                            
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 pb-4 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success-subtle text-success rounded-circle d-flex align-items-center justify-content-center me-3 border border-success-subtle" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-user-tie h5 mb-0"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@Model.AuthorName</div>
                                        <div class="text-muted small">Đăng ngày @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <button onclick="toggleLike('@Model.Id')" class="btn @(Model.IsLikedByCurrentUser ? "btn-danger" : "btn-outline-danger") rounded-pill px-4 shadow-sm transition-all shadow-hover" id="likeBtn">
                                        <i class="@(Model.IsLikedByCurrentUser ? "fa-solid" : "fa-regular") fa-heart me-2"></i>
                                        <span id="likeCount">@Model.LikeCount</span> lượt thích
                                    </button>
                                    <div class="text-muted border-start ps-3"><i class="fa-solid fa-comment me-2"></i>@Model.Comments.Count bình luận</div>
                                </div>
                            </div>
                        </header>

                        <!-- Main Thumbnail Image -->
                        @if (!string.IsNullOrEmpty(Model.Thumbnail))
                        {
                            <div class="rounded-4 overflow-hidden mb-5 shadow-sm">
                                <img src="@Model.Thumbnail" alt="@Model.Title" class="w-100 h-auto object-fit-cover" style="max-height: 500px;">
                            </div>
                        }

                        <div class="blog-content fs-5 text-dark lh-lg mb-5">
                            @Html.Raw(Model.Content)
                        </div>

                        @if (Model.Category == BlogCategory.Sales && Model.ImageUrls != null && Model.ImageUrls.Any())
                        {
                            <!-- Multi Image Carousel for Sales Posts (Below Content) -->
                            <div class="mt-5 pt-4 border-top">
                                <h4 class="fw-bold mb-4"><i class="fa-solid fa-images me-2 text-success"></i>Hình ảnh thực tế</h4>
                                <div id="salesGallery" class="carousel slide rounded-4 overflow-hidden shadow-sm shadow-hover mb-5" data-bs-ride="carousel">
                                    <div class="carousel-indicators">
                                        @for (int i = 0; i < Model.ImageUrls.Count; i++)
                                        {
                                            <button type="button" data-bs-target="#salesGallery" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")"></button>
                                        }
                                    </div>
                                    <div class="carousel-inner h-100">
                                        @foreach (var img in Model.ImageUrls)
                                        {
                                            <div class="carousel-item @(img == Model.ImageUrls.First() ? "active" : "")">
                                                <a href="@img" data-fancybox="gallery">
                                                    <img src="@img" alt="@Model.Title" class="d-block w-100 object-fit-cover" style="max-height: 550px; min-height: 400px;">
                                                </a>
                                            </div>
                                        }
                                    </div>
                                    <button class="carousel-control-prev" type="button" data-bs-target="#salesGallery" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#salesGallery" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"></span>
                                    </button>
                                </div>

                                <!-- Grid thumbnails for quick access -->
                                <div class="row g-3">
                                    @foreach (var img in Model.ImageUrls)
                                    {
                                        <div class="col-4 col-md-3 col-lg-2">
                                            <div class="rounded-3 overflow-hidden shadow-sm shadow-hover transition-all border p-1 bg-white cursor-pointer" onclick="$('#salesGallery').carousel(@Model.ImageUrls.IndexOf(img))">
                                                <img src="@img" class="w-100 object-fit-cover" style="height: 60px;">
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.Tags))
                        {
                            <div class="mt-5 d-flex flex-wrap gap-2 pt-4 border-top">
                                <span class="text-muted small fw-bold me-2 align-self-center"><i class="fa-solid fa-tags me-1"></i>Tags:</span>
                                @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <a asp-action="Index" asp-route-searchTerm="@tag.Trim()" asp-route-category="@Model.Category" class="text-decoration-none small text-muted bg-light px-3 py-1 rounded-pill border transition-all hover-bg-success-subtle hover-text-success">
                                        <i class="fa-solid fa-hashtag small opacity-50 me-1"></i>@tag.Trim()
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </article>

                <!-- Comments Section -->
                <section class="comments-section" id="comments">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h3 class="fw-bold m-0"><i class="fa-solid fa-comments me-2 text-primary"></i>Thảo luận (@Model.Comments.Count)</h3>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="card border-0 shadow-sm rounded-4 p-4 mb-5 bg-white">
                            <div class="d-flex gap-3">
                                <div class="flex-grow-1">
                                    <textarea id="commentContent" class="form-control border-light bg-light rounded-4 p-3 shadow-none focus-ring-success" rows="3" placeholder="Chia sẻ cảm nghĩ của bạn về bài viết..."></textarea>
                                    <div class="d-flex justify-content-end mt-3">
                                        <button onclick="addComment('@Model.Id')" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm transition-all hover-lift">
                                            <i class="fa-solid fa-paper-plane me-2"></i>Gửi bình luận
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-soft-warning rounded-4 border-0 shadow-sm p-4 text-center mb-5">
                           Vui lòng <a asp-controller="Account" asp-action="Login" class="fw-bold text-decoration-none text-warning text-darken-2">đăng nhập</a> để tham gia thảo luận.
                        </div>
                    }

                    <div id="commentsList" class="d-flex flex-column gap-4">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="comment-item d-flex gap-3 p-4 bg-white rounded-4 shadow-sm border border-light transition-all">
                                <div class="rounded-circle bg-success-subtle text-success d-flex align-items-center justify-content-center flex-shrink-0 border border-white shadow-sm" style="width: 50px; height: 50px;">
                                    @if (!string.IsNullOrEmpty(comment.UserAvatar))
                                    {
                                        <img src="@comment.UserAvatar" class="w-100 h-100 rounded-circle object-fit-cover">
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-user small"></i>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="fw-bold mb-0 text-dark">@comment.UserName</h6>
                                        <span class="text-muted small"><i class="fa-regular fa-clock me-1"></i>@comment.CreatedAt.ToString("dd/MM, HH:mm")</span>
                                    </div>
                                    <p class="text-muted mb-0 lh-base">@comment.Content</p>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <div class="text-center mt-5">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5 py-2 transition-all shadow-hover">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --bs-success-rgb: 45, 106, 79;
        --success-soft: rgba(45, 106, 79, 0.1);
    }

    .bg-light-gray { background-color: #f4f7f6; }
    
    .blog-card {
        border: none;
        transition: all 0.3s ease;
    }

    .post-media {
        position: relative;
        overflow: hidden;
    }

    .post-category-badge {
        position: absolute;
        bottom: 20px;
        left: 20px;
        z-index: 10;
    }

    .blog-content {
        color: #333;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .blog-content img { 
        max-width: 100%; 
        height: auto !important; 
        border-radius: 1.5rem; 
        margin: 2.5rem 0; 
        box-shadow: 0 20px 40px rgba(0,0,0,0.08); 
    }

    .blog-content h2 { 
        font-weight: 800; 
        color: #1b4332; 
        margin-top: 3.5rem; 
        margin-bottom: 1.5rem; 
        letter-spacing: -0.02em;
    }

    .blog-content p { margin-bottom: 1.8rem; }

    .comment-item { border: 1px solid transparent !important; }
    .comment-item:hover { 
        border-color: #d8e2dc !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }

    .hover-text-success:hover { color: #2d6a4f !important; }
    
    .focus-ring-success:focus {
        border-color: #2d6a4f !important;
        box-shadow: 0 0 0 0.25rem rgba(45, 106, 79, 0.15) !important;
    }

    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }

    .shadow-hover { transition: all 0.3s ease; }
    .shadow-hover:hover { box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important; }

    .alert-soft-warning {
        background-color: #fffcf0;
        border-left: 4px solid #ffc107 !important;
    }

    /* Custom styles for blockquotes in blog content */
    .blog-content blockquote {
        border-left: 5px solid #2d6a4f;
        padding: 1.5rem 2rem;
        background: #f8fbf9;
        font-style: italic;
        margin: 2.5rem 0;
        border-radius: 0 1rem 1rem 0;
    }

    /* Carousel Customization */
    .carousel-indicators [data-bs-target] {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin: 0 5px;
    }
    .carousel-control-prev, .carousel-control-next {
        width: 10%;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    #salesGallery:hover .carousel-control-prev, 
    #salesGallery:hover .carousel-control-next {
        opacity: 0.8;
    }
    .carousel-control-prev-icon, .carousel-control-next-icon {
        background-color: rgba(0,0,0,0.3);
        padding: 1.5rem;
        border-radius: 50%;
        background-size: 50%;
    }
</style>

@section Scripts {
    <script>
        function toggleLike(postId) {
            $.post('/Blog/ToggleLike', { postId: postId }, function (data) {
                if (data.success) {
                    const btn = document.getElementById('likeBtn');
                    const icon = btn.querySelector('i');
                    const countSpan = document.getElementById('likeCount');
                    let count = parseInt(countSpan.innerText);

                    if (data.isLiked) {
                        btn.classList.replace('btn-outline-danger', 'btn-danger');
                        icon.classList.replace('fa-regular', 'fa-solid');
                        countSpan.innerText = count + 1;
                    } else {
                        btn.classList.replace('btn-danger', 'btn-outline-danger');
                        icon.classList.replace('fa-solid', 'fa-regular');
                        countSpan.innerText = count - 1;
                    }
                }
            }).fail(() => window.location.href = '/Account/Login');
        }

        function addComment(postId) {
            const content = document.getElementById('commentContent').value;
            if (!content.trim()) return;

            $.post('/Blog/AddComment', { postId: postId, content: content }, function (data) {
                if (data.success) {
                    document.getElementById('commentContent').value = '';
                    const comment = data.comment;
                    const date = new Date(comment.createdAt);
                    const formattedDate = date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit' }) + ', ' + date.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                    
                    const avatarContent = comment.userAvatar 
                        ? `<img src="${comment.userAvatar}" class="w-100 h-100 rounded-circle object-fit-cover shadow-sm">`
                        : `<i class="fa-solid fa-user small"></i>`;

                    const html = `
                        <div class="comment-item d-flex gap-3 p-4 bg-white rounded-4 shadow-sm border animate__animated animate__fadeIn">
                            <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                                ${avatarContent}
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0">${comment.userName}</h6>
                                    <span class="text-muted small">${formattedDate}</span>
                                </div>
                                <p class="text-muted mb-0 lh-base">${comment.content}</p>
                            </div>
                        </div>
                    `;
                    $('#commentsList').prepend(html);
                    Swal.fire({
                        icon: 'success',
                        title: 'Đã đăng bình luận!',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000
                    });
                } else {
                    Swal.fire('Lỗi!', data.message, 'error');
                }
            });
        }
    </script>
}
