@using EcommerceApp.Enums
@model IEnumerable<EcommerceApp.Application.DTOs.Blog.BlogPostDto>
@{
    var category = (BlogCategory?)ViewData["Category"];
    var title = category == BlogCategory.Sales ? "Bài viết sản phẩm" : "Kinh nghiệm & Bí quyết";
    var description = category == BlogCategory.Sales 
        ? "Khám phá các sản phẩm nổi bật và tin tức ưu đãi mới nhất từ Green Life." 
        : "Nơi chia sẻ những kiến thức hữu ích về chăm sóc cây cảnh và không gian sống xanh.";
    ViewData["Title"] = title;
}

@{
    var bannerImg = category == BlogCategory.Sales 
        ? "https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&q=80&w=2000"
        : "https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?auto=format&fit=crop&q=80&w=2000";
}

<div class="blog-banner py-5 text-white position-relative overflow-hidden" 
     style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.4)), url('@bannerImg') center/cover; min-height: 300px; display: flex; align-items: center;">
    <div class="container text-center py-5">
        <h1 class="fw-bold display-4 mb-3 animate__animated animate__fadeInDown">@title</h1>
        <p class="fs-5 opacity-75 mb-0 animate__animated animate__fadeInUp">@description</p>
    </div>
</div>

<div class="container mb-5" style="margin-top: -35px; position: relative; z-index: 10;">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <form asp-action="Index" method="get" class="search-form p-2 bg-white shadow-lg rounded-pill border">
                <input type="hidden" name="category" value='@ViewData["Category"]' />
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-muted ps-3">
                        <i class="fa-solid fa-magnifying-glass fs-5"></i>
                    </span>
                    <input type="text" name="searchTerm" class="form-control border-0 bg-transparent py-3 fs-6" 
                           placeholder="Bạn đang tìm kiếm gì?..." value="@ViewData["SearchTerm"]" style="box-shadow: none;">
                    <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold transition-all px-lg-5">
                        <span class="d-none d-sm-inline">Tìm kiếm</span>
                        <i class="fa-solid fa-arrow-right d-sm-none"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        @foreach (var post in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 transition-transform hover-translate-y">
                    <a asp-action="Details" asp-route-id="@post.Id" class="text-decoration-none">
                        <div class="position-relative overflow-hidden" style="aspect-ratio: 16/9;">
                            @if (!string.IsNullOrEmpty(post.Thumbnail))
                            {
                                <img src="@post.Thumbnail" class="w-100 h-100 object-fit-cover transition-all duration-500 hover-scale" alt="@post.Title">
                            }
                            else
                            {
                                <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center text-muted">
                                    <i class="fa-solid fa-seedling h1 opacity-25"></i>
                                </div>
                            }
                        </div>
                    </a>
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 fw-bold small">
                                @(post.Category == BlogCategory.Sales ? "Bài viết" : "Kinh nghiệm")
                            </span>
                            <span class="text-muted small italic">@post.CreatedAt?.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h3 class="h5 fw-bold mb-2">
                            <a asp-action="Details" asp-route-id="@post.Id" class="text-dark text-decoration-none hover-text-success">@post.Title</a>
                        </h3>
                        
                        @if (!string.IsNullOrEmpty(post.Tags))
                        {
                            <div class="mb-3 d-flex flex-wrap gap-2">
                                @foreach (var tag in post.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <a asp-action="Index" asp-route-searchTerm="@tag.Trim()" class="text-decoration-none small text-muted bg-light px-2 py-1 rounded-pill hover-bg-success-subtle">
                                        <i class="fa-solid fa-hashtag small opacity-50"></i>@tag.Trim()
                                    </a>
                                }
                            </div>
                        }

                        <p class="text-muted small mb-4 line-clamp-3">
                            @(System.Text.RegularExpressions.Regex.Replace(post.Content ?? "", "<.*?>", String.Empty))
                        </p>
                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2 text-primary" style="width: 32px; height: 32px;">
                                    <i class="fa-solid fa-user-pen" style="font-size: 0.8rem;"></i>
                                </div>
                                <span class="small fw-bold text-dark">@post.AuthorName</span>
                            </div>
                            <div class="text-muted small">
                                <i class="fa-solid fa-heart me-1 text-danger"></i> @post.LikeCount
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            @if (!string.IsNullOrEmpty(ViewData["SearchTerm"]?.ToString()))
            {
                <i class="fa-solid fa-magnifying-glass-chart h1 text-muted opacity-25 mb-3"></i>
                <h4 class="fw-bold">Không tìm thấy bài viết nào</h4>
                <p class="text-muted">Rất tiếc, chúng tôi không tìm thấy bài viết nào khớp với từ khóa <strong>"@ViewData["SearchTerm"]"</strong>. Hãy thử lại với từ khóa khác nhé!</p>
                <a asp-action="Index" class="btn btn-outline-success mt-3 rounded-pill px-4">Xem tất cả bài viết</a>
            }
            else
            {
                <i class="fa-solid fa-mug-hot h1 text-muted opacity-25 mb-3"></i>
                <p class="text-muted">Chúng tôi đang chuẩn bị những nội dung tuyệt vời nhất cho bạn. Quay lại sau nhé!</p>
            }
        </div>
    }
</div>

<style>
    .hover-translate-y:hover { transform: translateY(-10px); }
    .hover-scale:hover { transform: scale(1.05); }
    .hover-text-success:hover { color: #2d6a4f !important; }
    .transition-all { transition: all 0.4s ease; }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
