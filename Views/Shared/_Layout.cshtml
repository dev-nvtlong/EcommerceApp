<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Shop</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="main-header">
        <div class="main-header__container">
            <a class="main-header__logo" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-seedling"></i>
                <span>Green Life</span>
            </a>
            
            <nav class="main-header__nav">
                <a class="main-header__link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                <a class="main-header__link" asp-area="" asp-controller="Shop" asp-action="Index">Cây & Sản phẩm</a>
                <a class="main-header__link" asp-area="" asp-controller="Blog" asp-action="Index">Kinh nghiệm</a>
                <a class="main-header__link" asp-area="" asp-controller="Home" asp-action="Privacy">Về chúng tôi</a>
            </nav>
            
            <div class="main-header__actions">
                <div class="main-header__action">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                <a asp-controller="Cart" asp-action="Index" class="main-header__action text-decoration-none">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span id="cart-badge" class="main-header__badge">0</span>
                </a>
                <div class="dropdown main-header__user">
                    <a href="#" class="main-header__action text-decoration-none" data-bs-toggle="dropdown">
                        <i class="fa-regular fa-user"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4 mt-3 p-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="px-3 py-2 border-bottom mb-2">
                                <span class="d-block fw-bold small">Chào, @User.Identity.Name</span>
                            </li>
                            <li><a class="dropdown-item rounded-3 py-2 small" asp-controller="Account" asp-action="Profile"><i class="fa-solid fa-circle-user me-2"></i> Hồ sơ</a></li>
                            <li><a class="dropdown-item rounded-3 py-2 small" asp-controller="Order" asp-action="Index"><i class="fa-solid fa-clock-rotate-left me-2"></i> Đơn hàng</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item rounded-3 py-2 small text-danger">
                                        <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a class="dropdown-item rounded-3 py-2 small" asp-controller="Account" asp-action="Auth" asp-route-mode="login"><i class="fa-solid fa-right-to-bracket me-2"></i> Đăng nhập</a></li>
                            <li><a class="dropdown-item rounded-3 py-2 small fw-bold text-primary" asp-controller="Account" asp-action="Auth" asp-route-mode="register"><i class="fa-solid fa-user-plus me-2"></i> Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="container text-white py-5">
            <div class="row gy-4">
                <div class="col-lg-4 col-md-6 mb-4">
                    <h5 class="fw-bold mb-4 text-emerald-300">
                        <i class="fa-solid fa-seedling me-2"></i> GREEN LIFE
                    </h5>
                    <p class="text-white-50 small mb-4 pe-lg-4">
                        Tôn vinh cuộc sống xanh bằng cách mang không gian thiên nhiên vào chính ngôi nhà của bạn. Với chúng tôi, mỗi cái cây đều mang một câu chuyện riêng.
                    </p>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle shadow-sm" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle shadow-sm" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle shadow-sm" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-tiktok"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle shadow-sm" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;"><i class="fa-brands fa-youtube"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4 opacity-75">Sản phẩm</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" asp-controller="Shop" asp-action="Index">Tất cả sản phẩm</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Cây nội thất</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Cây ngoài trời</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Chậu & Phụ kiện</a></li>
                    </ul>
                </div>

                <div class="col-lg-2 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4 opacity-75">Thông tin</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" asp-controller="Home" asp-action="Privacy">Về chúng tôi</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Chính sách bảo mật</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Điều khoản sử dụng</a></li>
                        <li class="mb-2"><a class="text-white-50 text-decoration-none hover-white" href="#">Hướng dẫn chăm sóc</a></li>
                    </ul>
                </div>

                <div class="col-lg-4 col-md-6 mb-4">
                    <h6 class="fw-bold mb-4 opacity-75">Đăng ký nhận tin</h6>
                    <p class="text-white-50 small mb-3">Nhận ngay mẹo chăm sóc cây và các chương trình ưu đãi mới nhất từ Green Life.</p>
                    <div class="input-group mb-3">
                        <input type="text" class="form-control bg-dark border-secondary text-white small" placeholder="Email của bạn..." aria-label="Email" style="border-radius: 50px 0 0 50px; background-color: rgba(255,255,255,0.05) !important;">
                        <button class="btn btn-primary px-4" type="button" style="border-radius: 0 50px 50px 0;">Gửi</button>
                    </div>
                    <div class="small text-white-50 mt-3 pt-2 border-top border-secondary border-opacity-25">
                        <div class="mb-2"><i class="fa-solid fa-location-dot me-3 text-primary"></i> 456 Đường Láng, Đống Đa, Hà Nội</div>
                        <div class="mb-2"><i class="fa-solid fa-phone me-3 text-primary"></i> +84 (24) 3456 7890</div>
                        <div><i class="fa-solid fa-envelope me-3 text-primary"></i> contact@greenlife.vn</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="main-footer__bottom py-4 text-center border-top border-secondary border-opacity-10">
            <p class="text-white-50 small mb-0">&copy; @DateTime.Now.Year GREEN LIFE. Bản quyền thuộc về Green Life Team.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function updateCartBadge() {
            $.get('/Cart/GetCartSummary', function(res) {
                $('#cart-badge').text(res.totalItems);
            });
        }

        function addToCart(productId, quantity = 1) {
            @if (User.Identity?.IsAuthenticated != true)
            {
                <text>
                window.location.href = '/Account/Auth';
                return;
                </text>
            }
            $.post('/Cart/AddToCart', { productId: productId, quantity: quantity }, function(res) {
                if (res.success) {
                    updateCartBadge();
                    Swal.fire({
                        title: 'Thành công!',
                        text: 'Sản phẩm đã được thêm vào giỏ hàng.',
                        icon: 'success',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true
                    });
                }
            }).fail(function() {
                window.location.href = '/Account/Auth';
            });
        }

        function buyNow(productId, quantity = 1) {
            @if (User.Identity?.IsAuthenticated != true)
            {
                <text>
                window.location.href = '/Account/Auth';
                return;
                </text>
            }
            $.post('/Cart/AddToCart', { productId: productId, quantity: quantity }, function(res) {
                if (res.success) {
                    window.location.href = '/Order/Checkout';
                }
            }).fail(function() {
                window.location.href = '/Account/Auth';
            });
        }

        $(document).ready(function() {
            updateCartBadge();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
